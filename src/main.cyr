# chakshu — main entry point
# The eye — AI-augmented system monitor for AGNOS / Cyrius.
# Stdlib auto-included via cyrius.cyml.
#
# Project modules — split per design-spec §1 (proc reads / snapshot
# rendering / TUI / AI all separate concerns). The CLAUDE.md
# architecture stub pre-supposes a proc/ subdir; we'll promote
# proc.cyr → proc/{cpu,disk,net,pid}.cyr when M1 Slice B/C land
# and the file gets unwieldy. Flat is fine while the parsers fit.
include "lib/darshana.cyr"
include "src/proc.cyr"
include "src/processes.cyr"
include "src/snapshot.cyr"
include "src/tui.cyr"

# Keep CHAKSHU_VERSION in sync with the VERSION file.
# A future CI check will enforce equality; for now, manual.
var CHAKSHU_VERSION = "chakshu 0.2.5";

# Exit codes per design-spec §9
var EXIT_OK    = 0;
var EXIT_ERR   = 1;
var EXIT_USAGE = 2;

fn print_version() {
    println(CHAKSHU_VERSION);
    return EXIT_OK;
}

fn print_help() {
    println("chakshu — AI-augmented system monitor for AGNOS");
    println("");
    println("Usage:");
    println("  shu [OPTIONS]            Full TUI: ↑↓ select, s sort, f filter, k kill, q quit");
    println("  shu -p                   Plain snapshot (host/uptime/load/mem/cpu/disk/net + top-N process table)");
    println("  shu --pid <PID>          Focus a single process (M2+)");
    println("  shu --explain <PID>      AI explanation (M3+)");
    println("  shu --watch              Anomaly stream (M3+)");
    println("");
    println("Options:");
    println("  -p                        Plain snapshot mode (single frame to stdout)");
    println("  --sort cpu|mem|pid|name   Process-table sort key (default cpu)");
    println("  --top N                   Process-table row count (default 10)");
    println("  --rate <HZ>               TUI refresh rate (integer 1-10, default 1; fractional Hz later)");
    println("  --color <when>            auto | always | never (default auto) [M2+]");
    println("  --pid <PID>               Focus a single process [M2+]");
    println("  --explain <PID>           Print AI explanation and exit [M3+]");
    println("  --watch                   Anomaly stream mode [M3+]");
    println("  --with-logs               Allow AI prompts to include sakshi log context [M3+]");
    println("  -h, --help                Show this help");
    println("  -V, --version             Show version");
    println("");
    println("Status: v0.1.0 scaffold. Most flags are placeholders pending");
    println("M1-M3. See docs/development/roadmap.md.");
    return EXIT_OK;
}

# Per design-spec §9: errors go to stderr as `chakshu: <reason>`.
# Helpers: write a c-string (with/without newline) to stderr without
# manual byte counting. The em dash in the unimplemented message is
# 3 UTF-8 bytes; manual counts on multi-fragment messages have already
# bitten us twice (off-by-one on the unimplemented dash; off-by-one
# on the --sort error literal yielding a stray leading space). Use
# these for any new stderr writes.
fn eprint_cstr(s) {
    eprint(s, strlen(s));
    return 0;
}

fn eprintln(s) {
    eprint_cstr(s);
    eprint("\n", 1);
    return 0;
}

fn print_unimplemented(flag) {
    eprint_cstr("chakshu: ");
    eprint_cstr(flag);
    eprintln(" not implemented yet — see docs/development/roadmap.md");
    return EXIT_ERR;
}

fn print_unknown_flag(flag) {
    eprint_cstr("chakshu: unknown flag: ");
    eprintln(flag);
    eprintln("Try 'shu --help' for usage.");
    return EXIT_USAGE;
}

fn main() {
    args_init();

    var n = argc();

    # Bare `shu` (no args) falls through to the dispatch at the
    # bottom — the args loop just doesn't iterate, no mode flag gets
    # set, and the default-mode line at the bottom launches the TUI
    # with default sort/top/rate. Single dispatch path.

    # Accumulate flags first, then dispatch at the bottom. Mode flags
    # (-h, -V, -p) are mutually exclusive; the last one in the args
    # list wins (matches the convention of most CLIs).
    var mode_help    = 0;
    var mode_version = 0;
    var mode_p       = 0;

    var sort_key    = SORT_CPU;
    var top_n       = PROC_DEFAULT_TOPN;
    var tui_rate_hz = 1;                # default 1 Hz (1000 ms refresh)

    var i = 1;
    while (i < n) {
        var a = argv(i);

        if (streq(a, "-h") == 1)        { mode_help = 1;    i = i + 1; continue; }
        if (streq(a, "--help") == 1)    { mode_help = 1;    i = i + 1; continue; }
        if (streq(a, "-V") == 1)        { mode_version = 1; i = i + 1; continue; }
        if (streq(a, "--version") == 1) { mode_version = 1; i = i + 1; continue; }
        if (streq(a, "-p") == 1)        { mode_p = 1;       i = i + 1; continue; }

        # --sort cpu|mem|pid|name (default cpu).
        if (streq(a, "--sort") == 1) {
            if (i + 1 >= n) {
                eprintln("chakshu: --sort requires a value (cpu|mem|pid|name)");
                return EXIT_USAGE;
            }
            var v = argv(i + 1);
            if      (streq(v, "cpu")  == 1) { sort_key = SORT_CPU; }
            elif    (streq(v, "mem")  == 1) { sort_key = SORT_MEM; }
            elif    (streq(v, "pid")  == 1) { sort_key = SORT_PID; }
            elif    (streq(v, "name") == 1) { sort_key = SORT_NAME; }
            else {
                eprint_cstr("chakshu: --sort: unknown key '");
                eprint_cstr(v);
                eprintln("' (want cpu|mem|pid|name)");
                return EXIT_USAGE;
            }
            i = i + 2;
            continue;
        }

        # --rate <Hz> (default 1; integer 1-10 for Slice C — fractional
        # Hz like 0.2 needs atof which the stdlib doesn't expose yet).
        if (streq(a, "--rate") == 1) {
            if (i + 1 >= n) {
                eprintln("chakshu: --rate requires Hz (integer 1-10)");
                return EXIT_USAGE;
            }
            var rv = atoi(argv(i + 1));
            if (rv < 1) {
                eprintln("chakshu: --rate: Hz must be >= 1 (fractional Hz lands later)");
                return EXIT_USAGE;
            }
            if (rv > 10) {
                eprintln("chakshu: --rate: Hz must be <= 10 (above this each frame can't fit its 100ms sample window)");
                return EXIT_USAGE;
            }
            tui_rate_hz = rv;
            i = i + 2;
            continue;
        }

        # --top N (default 10). Negative or zero is rejected — those
        # would show no rows and waste the parse work.
        if (streq(a, "--top") == 1) {
            if (i + 1 >= n) {
                eprintln("chakshu: --top requires N (positive integer)");
                return EXIT_USAGE;
            }
            var nv = atoi(argv(i + 1));
            if (nv < 1) {
                eprintln("chakshu: --top: N must be >= 1");
                return EXIT_USAGE;
            }
            top_n = nv;
            i = i + 2;
            continue;
        }

        # Recognized flags that are not yet implemented — emit a
        # clear placeholder rather than a generic "unknown flag".
        if (streq(a, "--pid") == 1)       { return print_unimplemented("--pid"); }
        if (streq(a, "--explain") == 1)   { return print_unimplemented("--explain"); }
        if (streq(a, "--watch") == 1)     { return print_unimplemented("--watch"); }
        if (streq(a, "--color") == 1)     { return print_unimplemented("--color"); }
        if (streq(a, "--with-logs") == 1) { return print_unimplemented("--with-logs"); }

        return print_unknown_flag(a);
    }

    # Dispatch. Mode precedence: help > version > -p > default-help.
    if (mode_help    == 1) { return print_help(); }
    if (mode_version == 1) { return print_version(); }
    if (mode_p       == 1) { return snapshot_print(sort_key, top_n); }

    # Default mode — launch the TUI. tui_run handles the not-a-TTY
    # case (stdin redirected) by exiting EXIT_ERR with a stderr
    # message pointing at `-p`.
    return tui_run(_hz_to_ms(tui_rate_hz), sort_key, top_n);
}

# Convert --rate Hz to epoll_wait timeout in milliseconds. Used by
# tui_run dispatch above. Out-of-line so the validation lives next
# to the conversion (and so future fractional-Hz parsing has one
# place to land).
fn _hz_to_ms(hz) {
    return 1000 / hz;
}

var r = main();
syscall(SYS_EXIT, r);
