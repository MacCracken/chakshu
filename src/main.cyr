# chakshu — main entry point
# The eye — AI-augmented system monitor for AGNOS / Cyrius.
# Stdlib auto-included via cyrius.cyml.
#
# Project modules — split per design-spec §1 (proc reads / snapshot
# rendering / TUI / AI all separate concerns). The CLAUDE.md
# architecture stub pre-supposes a proc/ subdir; we'll promote
# proc.cyr → proc/{cpu,disk,net,pid}.cyr when M1 Slice B/C land
# and the file gets unwieldy. Flat is fine while the parsers fit.
include "src/proc.cyr"
include "src/processes.cyr"
include "src/snapshot.cyr"

# Keep CHAKSHU_VERSION in sync with the VERSION file.
# A future CI check will enforce equality; for now, manual.
var CHAKSHU_VERSION = "chakshu 0.1.0";

# Exit codes per design-spec §9
var EXIT_OK    = 0;
var EXIT_ERR   = 1;
var EXIT_USAGE = 2;

fn print_version() {
    println(CHAKSHU_VERSION);
    return EXIT_OK;
}

fn print_help() {
    println("chakshu — AI-augmented system monitor for AGNOS");
    println("");
    println("Usage:");
    println("  shu [OPTIONS]            Full TUI (M2+)");
    println("  shu -p                   Plain snapshot (host/uptime/load/mem; cpu+procs in M1 B/C)");
    println("  shu --pid <PID>          Focus a single process (M2+)");
    println("  shu --explain <PID>      AI explanation (M3+)");
    println("  shu --watch              Anomaly stream (M3+)");
    println("");
    println("Options:");
    println("  -p                        Plain snapshot mode (single frame to stdout)");
    println("  --rate <HZ>               Refresh rate (0.2-10, default 1)");
    println("  --color <when>            auto | always | never (default auto)");
    println("  --pid <PID>               Focus a single process");
    println("  --explain <PID>           Print AI explanation and exit");
    println("  --watch                   Anomaly stream mode");
    println("  --with-logs               Allow AI prompts to include sakshi log context");
    println("  -h, --help                Show this help");
    println("  -V, --version             Show version");
    println("");
    println("Status: v0.1.0 scaffold. Most flags are placeholders pending");
    println("M1-M3. See docs/development/roadmap.md.");
    return EXIT_OK;
}

# Per design-spec §9: errors go to stderr as `chakshu: <reason>`.
# Helper: write a c-string + newline to stderr without manual byte counting
# (the em dash in the unimplemented message is 3 UTF-8 bytes, easy to miscount).
fn eprintln(s) {
    eprint(s, strlen(s));
    eprint("\n", 1);
    return 0;
}

fn print_unimplemented(flag) {
    eprint("chakshu: ", 9);
    eprint(flag, strlen(flag));
    eprintln(" not implemented yet — see docs/development/roadmap.md");
    return EXIT_ERR;
}

fn print_unknown_flag(flag) {
    eprint("chakshu: unknown flag: ", 23);
    eprintln(flag);
    eprintln("Try 'shu --help' for usage.");
    return EXIT_USAGE;
}

fn main() {
    args_init();

    var n = argc();

    if (n < 2) {
        # No args — would launch TUI at M2+. Until then, print help.
        return print_help();
    }

    var i = 1;
    while (i < n) {
        var a = argv(i);

        if (streq(a, "-h") == 1)        { return print_help(); }
        if (streq(a, "--help") == 1)    { return print_help(); }
        if (streq(a, "-V") == 1)        { return print_version(); }
        if (streq(a, "--version") == 1) { return print_version(); }

        # M1 Slice A — `-p` plain snapshot. Top-N process table, --sort,
        # and --top come in Slices C/D; for now `-p` ignores any trailing
        # args so callers can prototype against the M1 surface today.
        if (streq(a, "-p") == 1)          { return snapshot_print(); }

        # Recognized flags that are not yet implemented — emit a
        # clear placeholder rather than a generic "unknown flag".
        if (streq(a, "--pid") == 1)       { return print_unimplemented("--pid"); }
        if (streq(a, "--explain") == 1)   { return print_unimplemented("--explain"); }
        if (streq(a, "--watch") == 1)     { return print_unimplemented("--watch"); }
        if (streq(a, "--rate") == 1)      { return print_unimplemented("--rate"); }
        if (streq(a, "--color") == 1)     { return print_unimplemented("--color"); }
        if (streq(a, "--with-logs") == 1) { return print_unimplemented("--with-logs"); }

        return print_unknown_flag(a);
    }

    return EXIT_OK;
}

var r = main();
syscall(SYS_EXIT, r);
