# tui.cyr — interactive full-screen monitor (M2).
#
# M2 Slice A: smallest viable TUI. Enter alt-screen, raw mode, hide
# cursor, paint a placeholder, read input one byte at a time, exit
# on 'q' or Ctrl-C.
# M2 Slice B: signal-safe cleanup. Block SIGHUP/SIGINT/SIGTERM and
# route them to a signalfd; epoll multiplexes stdin + signalfd so
# external `kill <pid>` triggers `_tui_teardown` instead of leaving
# the terminal in raw+alt-screen+cursor-hidden state.
# M2 Slice C: render loop. epoll_wait now uses a finite timeout
# (refresh_ms = 1000 / hz, default 1 Hz). On timeout we re-render
# the frame; on stdin/signalfd we dispatch as before. The render
# function pulls the same /proc data the M1 plain-mode snapshot
# does — duplicates the data-gather + format logic with TUI-friendly
# output (cursor positioning + clear-to-eol per line, no \n which
# wouldn't carriage-return in raw mode without OPOST). Future
# refactor candidate: extract a shared "snapshot data" core so
# plain mode and TUI render from one source.
# M2 Slice D: SIGWINCH + dynamic window size. Adds a second signalfd
# for SIGWINCH (separate from the exit-signalfd for clearer dispatch),
# wakes the render loop on resize, re-reads winsize via tty_winsize,
# caps the process table at (rows - 4) so it never overflows the
# terminal. Replaces the inline _tui_open_exit_signalfd / _tui_clear_*
# helpers with darshana 0.3.0 equivalents (tty_open_signalfd,
# tty_clear_to_eol, tty_clear_to_eos) — Phase 3 of the original
# TUI extraction plan complete.
# M2 Slice E: keybinds — ↑/↓ row selection + `s` cycles sort key.
# `_tui_read_key` now parses multi-byte CSI escape sequences (ESC [
# A/B/C/D for arrows). Selection state lives in module globals so
# any keypress can mutate it; render highlights the selected row
# with reverse-video. Sort key + top_n promoted to globals so `s`
# can cycle them without re-entering tui_run.
# M2 Slice E.5: filter mode + status line. Bottom terminal row
# reserved for a status line that shows keybind hints (Normal mode)
# or the active filter string (Filter mode). `f` enters Filter mode;
# typed printables append to the filter buffer, Backspace deletes,
# Enter exits to Normal (filter persists), Esc clears the filter +
# exits to Normal. Substring match against the per-process `comm`
# field (in-memory, fast path) with fall-through to `/proc/<pid>/cmdline`
# read so arg/path searches also work. Filtered indices materialized
# in `_tui_filtered_idx[]` so selection/viewport operate in filtered
# space.
# M2 Slice F: kill key + confirm. `k` (Normal mode) captures the
# selected row's pid and switches to TUI_MODE_CONFIRM_KILL. The
# status line shows `Kill PID <N>? [y/N]`; `y`/`Y` calls
# sys_kill(pid, SIGTERM=15) and returns to Normal; any other key
# cancels. Killed processes disappear on the next refresh tick;
# selection auto-clamps via the render's defensive recompute.
# M2 Slice G.2: 16-color theme + --color flag. Bold header labels,
# percentage bands (green/yellow/red on CPU% and MEM%), state-letter
# coloring (R=green, D=blue, Z=red, T=yellow, others dim). Inside
# the reverse-video selection bar, colors are suppressed so the
# highlight stays visually clean. --color {auto, always, never}
# CLI flag from main.cyr seeds the color-enabled global; auto
# currently behaves as always in TUI mode (plain mode is always
# uncolored).
# M2 Slice G.3: --pid N focus mode. Single-process detail view —
# header / pid+name+state / ppid+uid+threads+rss+mem% / full
# cmdline / status. tui_render_frame is now a dispatcher that
# picks tui_render_table_frame (default) vs tui_render_focus_frame
# based on _tui_focus_pid. Sort/filter/arrow keys are no-ops in
# focus mode; q/Ctrl-C exits, k kills the focused pid (confirm
# flow shared with table mode). Threads list / fd enumeration /
# focused-pid CPU% deferred to a polish slice.
# Slice G.4:
#   G.4 — M2 close review + audit
#
# All TTY primitives come from darshana — `tty_raw` / `tty_cooked` /
# `tty_alt_enter` / `tty_alt_leave` / `tty_clear` / `tty_cursor_*` /
# `tty_winsize` / `tty_open_signalfd` / `tty_clear_to_eol/eos`.
# The dist bundle lands at `lib/darshana.cyr` via cyrius deps.

# Input buffer for _tui_read_key. Why we need this:
#   1. file_read(0, &b, 4) with VMIN=1 returns 1-4 bytes — whatever
#      the kernel has queued. If we discard the trailing 1-3 bytes
#      we lose key events whenever multiple keys arrive during a
#      render tick (100ms — easily a few rapid keypresses).
#   2. Multi-byte CSI sequences (arrows: ESC [ A/B/C/D) need to be
#      detected at consume time, not read time, so an arrow embedded
#      in a multi-byte read still parses correctly.
# The fix: a 4-byte buffer that _tui_read_key consumes one event at
# a time. Combined with the buffer-drain loop at the top of tui_run's
# main loop (which consumes pending bytes before re-entering
# epoll_wait), no key gets dropped regardless of arrival batching.
var _tui_input_buf[4];
var _tui_input_n   = 0;
var _tui_input_pos = 0;

# Read one key event. Returns:
#   - a byte value (0..255) for a single-byte key
#   - one of KEY_UP/KEY_DOWN/KEY_LEFT/KEY_RIGHT for arrow CSI sequences
#   - -1 on EOF / read error
# Refills the buffer with file_read(0, ., 4) when empty; subsequent
# calls consume from the buffer before going back to the kernel.
fn _tui_read_key() {
    if (_tui_input_pos >= _tui_input_n) {
        _tui_input_n   = file_read(0, &_tui_input_buf, 4);
        _tui_input_pos = 0;
        if (_tui_input_n <= 0) { return 0 - 1; }
    }
    # Detect a CSI arrow sequence at the current position. Needs
    # 3 bytes available (ESC [ <letter>); falls through to single-
    # byte handling otherwise (including bare Esc → 0x1b).
    var avail = _tui_input_n - _tui_input_pos;
    if (avail >= 3) {
        if (load8(&_tui_input_buf + _tui_input_pos) == 0x1b) {
            if (load8(&_tui_input_buf + _tui_input_pos + 1) == 0x5b) {
                var c = load8(&_tui_input_buf + _tui_input_pos + 2);
                if (c == 0x41) { _tui_input_pos = _tui_input_pos + 3; return KEY_UP; }
                if (c == 0x42) { _tui_input_pos = _tui_input_pos + 3; return KEY_DOWN; }
                if (c == 0x43) { _tui_input_pos = _tui_input_pos + 3; return KEY_RIGHT; }
                if (c == 0x44) { _tui_input_pos = _tui_input_pos + 3; return KEY_LEFT; }
            }
        }
    }
    var b = load8(&_tui_input_buf + _tui_input_pos);
    _tui_input_pos = _tui_input_pos + 1;
    return b;
}

# True if there are unconsumed bytes in the input buffer. Used by
# tui_run to drain pending events before going back to epoll_wait.
fn _tui_input_pending() {
    if (_tui_input_pos < _tui_input_n) { return 1; }
    return 0;
}

# Restore terminal state. Idempotent — safe to call from multiple
# cleanup sites (q-quit, Ctrl-C in raw mode, signalfd handler).
# Order matters: cursor-show before cooked-mode so the visible
# cursor reappears in the user's shell, alt-leave last so the
# user's previous shell content comes back undistorted.
fn _tui_teardown() {
    tty_cursor_show();
    tty_cooked();
    tty_alt_leave();
    return 0;
}

# Cached terminal dimensions. Updated at startup and on every
# SIGWINCH; the render loop reads from these (no per-frame ioctl
# overhead). Defaults of 24x80 are the historical VT100 size — used
# only if tty_winsize ever fails (it shouldn't, since tty_raw
# already proved fd 0 is a TTY by the time we get here).
var _tui_rows = 24;
var _tui_cols = 80;

# Refresh the cached terminal size from TIOCGWINSZ. Called once in
# tui_run setup and on every SIGWINCH event. Swallows ioctl failure
# silently — caller already has the (possibly stale) cached values.
#
# Defensive: also rejects rows=0/cols=0 even though the ioctl reports
# success. PTYs created without an explicit winsize (e.g. Python's
# pty.fork() without TIOCSWINSZ) return that "successful zero" — we'd
# end up writing the status line at row 0 (= row 1 per VT spec) and
# stomping the header, plus clipping all status text to 0 bytes.
# Falls through to the cached defaults (24x80) when this happens.
fn _tui_update_winsize() {
    var rows = 0;
    var cols = 0;
    if (tty_winsize(0, &rows, &cols) == 0) {
        if (rows > 0) {
            if (cols > 0) {
                _tui_rows = rows;
                _tui_cols = cols;
            }
        }
    }
    return 0;
}

# Interactive state. Mutated by `s` (cycle sort) and ↑/↓ (move
# selection). Initialized from tui_run's params at startup; the
# render loop reads them every frame.
#
# _tui_selected_idx is the absolute index into _proc_recs (0 to
# min(_tui_top_n, _proc_n) - 1) — NOT relative to the viewport.
# _tui_view_offset is the absolute index of the first row drawn at
# the top of the visible table; the render loop draws records
# [view_offset .. view_offset + visible_rows]. Pressing ↓ at the
# bottom of the viewport scrolls the view down so selection stays
# visible (htop convention). Pressing ↑ at the top scrolls up.
var _tui_sort_key     = 0;
var _tui_top_n        = 10;
var _tui_selected_idx = 0;
var _tui_view_offset  = 0;

# 0 = table mode (default); else = the pid this TUI is focused on.
# Set once at tui_run startup from --pid; never mutated. Render
# dispatcher picks the appropriate frame fn based on this.
var _tui_focus_pid    = 0;

# Synthesized key codes for multi-byte CSI escape sequences. Returned
# by _tui_read_key alongside raw byte values 0..255 — chosen above
# the byte range so the dispatch can switch on a single integer.
var KEY_UP    = 1000;
var KEY_DOWN  = 1001;
var KEY_LEFT  = 1002;
var KEY_RIGHT = 1003;

# Reverse-video on/off (CSI 7m / CSI 0m). Used to highlight the
# selected row in the process table. Inline here for now; promotes
# to darshana when a second consumer (cyim's syntax highlighting
# uses richer attributes — different need) wants the same primitive.
fn _tui_invert_on()  { syscall(1, 1, "\x1b[7m", 4); return 0; }
fn _tui_invert_off() { syscall(1, 1, "\x1b[0m", 4); return 0; }

# ---- color theme (Slice G.2) -------------------------------------
# _tui_color_enabled: 1 → emit ANSI color escapes; 0 → no-op.
# Set by tui_run from the --color CLI flag (auto/always = 1, never = 0).
# _tui_color_suppress: 1 inside the selected-row render so colors
# don't fight the reverse-video highlight visually.
var _tui_color_enabled  = 1;
var _tui_color_suppress = 0;

# Emit a raw ANSI escape if color is on AND not suppressed. Single
# choke point — keeps the apply sites readable (`_tui_color_red()`
# rather than `if enabled && !suppress: write(...)` everywhere).
fn _tui_color_emit(s) {
    if (_tui_color_enabled == 0) { return 0; }
    if (_tui_color_suppress == 1) { return 0; }
    syscall(1, 1, s, strlen(s));
    return 0;
}

# CSI SGR shortcuts. Reset uses CSI 0m (full attribute reset) — the
# render is structured so reset never fires inside reverse-video
# regions (suppress flag), so we don't need a "fg-only reset" variant.
fn _tui_color_red()    { _tui_color_emit("\x1b[31m"); return 0; }
fn _tui_color_green()  { _tui_color_emit("\x1b[32m"); return 0; }
fn _tui_color_yellow() { _tui_color_emit("\x1b[33m"); return 0; }
fn _tui_color_blue()   { _tui_color_emit("\x1b[34m"); return 0; }
fn _tui_color_cyan()   { _tui_color_emit("\x1b[36m"); return 0; }
fn _tui_color_dim()    { _tui_color_emit("\x1b[2m");  return 0; }
fn _tui_color_bold()   { _tui_color_emit("\x1b[1m");  return 0; }
fn _tui_color_reset()  { _tui_color_emit("\x1b[0m");  return 0; }

# Pick a color for a percent value: green below `low`, yellow below
# `mid`, red at `mid` or above. Used for CPU% and MEM% column tints.
fn _tui_color_pct_band(pct, low, mid) {
    if (pct < low) { _tui_color_green();  return 0; }
    if (pct < mid) { _tui_color_yellow(); return 0; }
    _tui_color_red();
    return 0;
}

# Pick a color for a Linux process state byte (R/S/D/Z/T/I/...).
# Convention matches htop roughly: running things stand out, broken
# things alarm, sleeping is quiet, kernel-internal idle is cyan
# (distinct semantic — these are kworker/* type threads).
fn _tui_color_state(s) {
    if (s == 82) { _tui_color_green();  return 0; }   # R running
    if (s == 68) { _tui_color_blue();   return 0; }   # D uninterruptible
    if (s == 90) { _tui_color_red();    return 0; }   # Z zombie
    if (s == 84) { _tui_color_yellow(); return 0; }   # T stopped
    if (s == 73) { _tui_color_cyan();   return 0; }   # I kernel idle
    _tui_color_dim();                                  # S sleeping, others
    return 0;
}

# Mode constants for the input state machine.
var TUI_MODE_NORMAL       = 0;
var TUI_MODE_FILTER       = 1;
var TUI_MODE_CONFIRM_KILL = 2;

# `k` captures the selected pid; `y` in confirm mode sends the
# signal. SIGTERM (15) is the polite-shutdown convention; SIGKILL
# (9) is too rude for a default keybind. Future slice could add a
# Shift-K for SIGKILL or a confirm-with-options overlay.
var TUI_KILL_SIGNUM = 15;
var _tui_kill_pid   = 0;

# Filter buffer: caps at 64 bytes (comm is TASK_COMM_LEN=16, so 64 is
# overkill but cheap insurance in case future filtering targets the
# full cmdline). Reset on Esc; mutated by typed printables and
# Backspace while in Filter mode.
var TUI_FILTER_MAX = 64;
var _tui_mode      = 0;          # TUI_MODE_NORMAL
var _tui_filter_buf[64];
var _tui_filter_n  = 0;

# Filtered process list — indices into _proc_recs, in sorted order.
# Built each frame after sample/sort. Selection + view_offset operate
# in filtered space (index into this array), not absolute proc_recs
# space. With an empty filter, _tui_filtered_idx[i] == i and
# _tui_filtered_n == _proc_n (the trivial pass-through).
#
# Sized for 1024 u64 entries = 8 KB — matches the PROC_MAX cap on
# proc_recs. Heap-equivalent footprint, fits comfortably.
var _tui_filtered_idx[8192];
var _tui_filtered_n = 0;

# Substring search: returns 1 if `haystack[0..hay_len)` contains the
# current filter buffer. Used for both comm-match and cmdline-match.
fn _tui_substr_match(haystack, hay_len) {
    if (hay_len < _tui_filter_n) { return 0; }
    var i = 0;
    var max_start = hay_len - _tui_filter_n;
    while (i <= max_start) {
        if (memeq(haystack + i, &_tui_filter_buf, _tui_filter_n) == 1) {
            return 1;
        }
        i = i + 1;
    }
    return 0;
}

# True if the proc at absolute index `rec_idx` matches the current
# filter. Empty filter matches everything. Tries `comm` first
# (in-memory, no syscall), falls through to a /proc/<pid>/cmdline
# read if comm doesn't match. comm-first short-circuit means typical
# process-name filters ("claude", "firefox") never trigger the
# per-process file read; only filters that need to match args
# ("--dangerous", "/usr/lib") pay the cost (~50us per cmdline read,
# so ~15ms total for 300 procs at 1Hz refresh — acceptable).
fn _tui_proc_matches_filter(rec_idx) {
    if (_tui_filter_n == 0) { return 1; }
    var rec = _proc_recs + rec_idx * PROC_REC_SIZE;

    # Pass 1 — match against the 16-byte comm field already in the
    # record. Cheapest path; covers process-name filters.
    var comm = rec + 32;
    if (_tui_substr_match(comm, strlen(comm)) == 1) { return 1; }

    # Pass 2 — read /proc/<pid>/cmdline and try again. Pays for
    # itself when the user's filter mentions args or paths.
    var pid = load64(rec + 0);
    var pid_str[24];
    _proc_int_to_cstr(pid, &pid_str);
    var cmd_buf[256];
    var cmd_n = _proc_read_cmdline(&pid_str, &cmd_buf, PROC_CMDLINE_MAX);
    if (cmd_n <= 0) { return 0; }
    return _tui_substr_match(&cmd_buf, cmd_n);
}

# Reset filter to empty + drop selection/viewport to the top. Called
# on Esc in Filter mode and (implicitly) when the buffer changes via
# typing/backspace — typing should put the cursor at the top of the
# newly-filtered list.
fn _tui_filter_reset_position() {
    _tui_selected_idx = 0;
    _tui_view_offset  = 0;
    return 0;
}

fn _tui_filter_clear() {
    _tui_filter_n = 0;
    _tui_filter_reset_position();
    return 0;
}

fn _tui_filter_append_byte(b) {
    if (_tui_filter_n >= TUI_FILTER_MAX) { return 0; }
    store8(&_tui_filter_buf + _tui_filter_n, b);
    _tui_filter_n = _tui_filter_n + 1;
    _tui_filter_reset_position();
    return 0;
}

fn _tui_filter_backspace() {
    if (_tui_filter_n > 0) {
        _tui_filter_n = _tui_filter_n - 1;
        _tui_filter_reset_position();
    }
    return 0;
}

# Cycle through SORT_CPU → MEM → PID → NAME → CPU. Called from `s`.
fn _tui_cycle_sort() {
    if (_tui_sort_key == SORT_CPU)       { _tui_sort_key = SORT_MEM; }
    elif (_tui_sort_key == SORT_MEM)     { _tui_sort_key = SORT_PID; }
    elif (_tui_sort_key == SORT_PID)     { _tui_sort_key = SORT_NAME; }
    else                                  { _tui_sort_key = SORT_CPU; }
    # Reset selection AND viewport on sort change — the row at the
    # prior index almost certainly maps to a different process now,
    # so leaving the highlight where it was would be misleading.
    _tui_selected_idx = 0;
    _tui_view_offset  = 0;
    return 0;
}

# Move selection within [0, max_navigable). max_navigable is the
# user-requested --top capped at actual process count — NOT bound
# by terminal height. Viewport (_tui_view_offset) scrolls to keep
# the selection visible: pressing ↓ at the bottom-visible row pushes
# the viewport down by one; pressing ↑ at the top scrolls up.
#
# This decouples "how many processes the user can navigate through"
# from "how many fit on screen at once" — a 6-row terminal can still
# scroll through all of --top 10's processes, two at a time.
fn _tui_select_up() {
    if (_tui_selected_idx > 0) {
        _tui_selected_idx = _tui_selected_idx - 1;
    }
    if (_tui_selected_idx < _tui_view_offset) {
        _tui_view_offset = _tui_selected_idx;
    }
    return 0;
}

fn _tui_select_down() {
    # max_navigable now uses _tui_filtered_n (the post-filter count)
    # so ↓ stops at the bottom of the filtered list, not the absolute
    # process list. _tui_filtered_n == _proc_n when the filter is empty.
    var max_navigable = _tui_filtered_n;
    if (max_navigable > _tui_top_n) { max_navigable = _tui_top_n; }
    if (_tui_selected_idx + 1 < max_navigable) {
        _tui_selected_idx = _tui_selected_idx + 1;
    }
    # Slice E.5: bottom row reserved for status line, so visible
    # process rows = _tui_rows - 5 (4 header rows + 1 status row).
    var max_rows = _tui_rows - 5;
    if (max_rows < 1) { max_rows = 1; }
    if (_tui_selected_idx >= _tui_view_offset + max_rows) {
        _tui_view_offset = _tui_selected_idx - max_rows + 1;
    }
    return 0;
}

# Top-level frame dispatcher. Every render path (initial paint,
# refresh tick, key event, SIGWINCH) calls this; it routes to
# table mode (default) or focus mode (--pid N from CLI).
fn tui_render_frame() {
    if (_tui_focus_pid != 0) {
        tui_render_focus_frame();
    } else {
        tui_render_table_frame();
    }
    return 0;
}

# Render the single-process focus view (--pid N). Layout:
#   row 1            host: <name>  up: <Nd HH:MM>  load: ...
#   row 2            ── PID <N> (<comm>) <state> ──
#   row 3            ppid: X  uid: X  threads: X  rss: X KiB  mem: X%
#   row 4            cmdline: <full cmdline, clipped to terminal width>
#   row _tui_rows    status: keybind hints
#
# If the focused pid no longer exists (process exited during refresh),
# rows 2-4 collapse to "PID <N> has exited." and the status row tells
# the user to press q.
fn tui_render_focus_frame() {
    var pid = _tui_focus_pid;
    var pid_str[24];
    _proc_int_to_cstr(pid, &pid_str);

    # ----- row 1: host/up/load (same as table mode) -----
    # M2.5: hostname / uptime via mihi. loadavg stays chakshu-local
    # (per-frame data, mihi doesn't own it).
    var hbuf[8192];
    var uts[400];
    mihi_uname(&uts);
    tty_cursor_home();
    _tui_color_bold(); syscall(1, 1, "host: ", 6); _tui_color_reset();
    var hn = mihi_hostname(&uts);
    syscall(1, 1, hn, strlen(hn));
    _tui_color_bold(); syscall(1, 1, "  up: ", 6); _tui_color_reset();
    snapshot_print_uptime(mihi_uptime_secs(&hbuf, 8192));
    _tui_color_bold(); syscall(1, 1, "  load: ", 8); _tui_color_reset();
    var la_n = proc_read("/proc/loadavg", &hbuf, 8192);
    if (la_n > 0) {
        var prefix = proc_loadavg_prefix_len(&hbuf, la_n);
        syscall(1, 1, &hbuf, prefix);
    }
    tty_clear_to_eol();

    # ----- read /proc/<pid>/stat — also tells us if the pid is still alive -----
    var stat_path[64];
    proc_pid_path(&pid_str, "/stat", &stat_path);
    var stat_buf[1024];
    var sn = file_read_all(&stat_path, &stat_buf, 1023);

    if (sn <= 0) {
        # Process gone — show terse exit message + clear the rest.
        tty_move(2, 1);
        _tui_color_bold(); _tui_color_red();
        syscall(1, 1, "PID ", 4);
        syscall(1, 1, &pid_str, strlen(&pid_str));
        syscall(1, 1, " has exited.", 12);
        _tui_color_reset();
        tty_clear_to_eol();
        if (3 < _tui_rows) {
            tty_move(3, 1);
            tty_clear_to_eos();
        }
        tty_move(_tui_rows, 1);
        syscall(1, 1, "[q] quit  (focused process exited)", 34);
        tty_clear_to_eol();
        return 0;
    }
    store8(&stat_buf + sn, 0);

    var srec[48];
    proc_pid_stat_parse(&stat_buf, sn, &srec);
    var state = load64(&srec + 0);
    var rss   = load64(&srec + 16);

    # ----- row 2: PID + comm + state header -----
    tty_move(2, 1);
    _tui_color_bold();
    syscall(1, 1, "── PID ", 11);   # box-drawing chars are 3 bytes each in UTF-8
    print_num(pid);
    syscall(1, 1, " (", 2);
    syscall(1, 1, &srec + 24, strlen(&srec + 24));
    syscall(1, 1, ") ", 2);
    _tui_color_reset();
    _tui_color_state(state);
    var sc[2];
    store8(&sc, state);
    store8(&sc + 1, 0);
    syscall(1, 1, &sc, 1);
    _tui_color_reset();
    _tui_color_bold(); syscall(1, 1, " ──", 4); _tui_color_reset();
    tty_clear_to_eol();

    # ----- read /proc/<pid>/status for ppid/uid/threads -----
    var status_path[64];
    proc_pid_path(&pid_str, "/status", &status_path);
    var status_buf[8192];
    var stn = file_read_all(&status_path, &status_buf, 8191);
    if (stn > 0) { store8(&status_buf + stn, 0); }
    var ppid_val    = proc_meminfo_field(&status_buf, "PPid:");
    var uid_val     = proc_meminfo_field(&status_buf, "Uid:");
    var threads_val = proc_meminfo_field(&status_buf, "Threads:");

    # ----- mem% for the focused pid -----
    var mi_buf[8192];
    var mem_total_b = mihi_mem_total(&mi_buf, 8192);
    var mem_total_kb = mem_total_b / 1024;
    var mem_pct = 0;
    if (mem_total_kb > 0) {
        mem_pct = rss * 400 / mem_total_kb;
    }

    # ----- row 3: ppid / uid / threads / rss / mem% -----
    tty_move(3, 1);
    _tui_color_bold(); syscall(1, 1, "ppid: ", 6); _tui_color_reset();
    print_num(ppid_val);
    _tui_color_bold(); syscall(1, 1, "  uid: ", 7); _tui_color_reset();
    print_num(uid_val);
    _tui_color_bold(); syscall(1, 1, "  threads: ", 11); _tui_color_reset();
    print_num(threads_val);
    _tui_color_bold(); syscall(1, 1, "  rss: ", 7); _tui_color_reset();
    print_num(rss * 4);   # rss in pages * 4KB/page = KiB on x86_64/aarch64
    syscall(1, 1, " KiB", 4);
    _tui_color_bold(); syscall(1, 1, "  mem: ", 7); _tui_color_reset();
    _tui_color_pct_band(mem_pct, 50, 80);
    print_num(mem_pct);
    _tui_color_reset();
    syscall(1, 1, "%", 1);
    tty_clear_to_eol();

    # ----- row 4: full cmdline -----
    tty_move(4, 1);
    _tui_color_bold(); syscall(1, 1, "cmdline: ", 9); _tui_color_reset();
    var cmd_buf[4096];
    var cmd_n = _proc_read_cmdline(&pid_str, &cmd_buf, 4096);
    var avail = _tui_cols - 9;
    if (avail < 0) { avail = 0; }
    if (cmd_n > 0) {
        var to_print = cmd_n;
        if (to_print > avail) { to_print = avail; }
        if (to_print > 0) { syscall(1, 1, &cmd_buf, to_print); }
    } else {
        # Kernel thread — show bracketed comm
        syscall(1, 1, "[", 1);
        syscall(1, 1, &srec + 24, strlen(&srec + 24));
        syscall(1, 1, "] (kernel thread)", 17);
    }
    tty_clear_to_eol();

    # ----- wipe rows between cmdline and status -----
    if (5 < _tui_rows) {
        tty_move(5, 1);
        tty_clear_to_eos();
    }

    # ----- status line: focus-mode keybinds -----
    tty_move(_tui_rows, 1);
    if (_tui_mode == TUI_MODE_CONFIRM_KILL) {
        var kpid_str[24];
        var kpid_len = _proc_int_to_cstr(_tui_kill_pid, &kpid_str);
        syscall(1, 1, "Kill PID ", 9);
        syscall(1, 1, &kpid_str, kpid_len);
        syscall(1, 1, "? [y/N]", 7);
    } else {
        syscall(1, 1, "[k] kill  [q] quit  (focus mode — single process)", 50);
    }
    tty_clear_to_eol();

    return 0;
}

# Render one full frame to the alt-screen. Mirrors snapshot_print()'s
# data gather but writes line-by-line via tty_move + clear-to-eol so
# successive frames overwrite cleanly. Same /proc reads + same 100ms
# inter-sample window for cpu/disk/net deltas — which means each call
# costs ~100ms wall time. At 1 Hz refresh that's 10% CPU; at 10 Hz
# it's 100% (do not run TUI at 10 Hz). Future slice optimizes by
# interleaving sample windows across frames.
#
# Reads sort key + top_n + selected_idx + view_offset from module
# globals so any input handler (s, ↑, ↓, future filter) can mutate
# them and trigger an immediate re-render without re-entering tui_run.
#
# top_n is the user-requested NAVIGABLE range (caps how many procs
# the user can scroll through). max_rows is the VISIBLE-window cap
# (how many fit on screen at once). These are intentionally
# decoupled — on a tiny terminal, the user can still scroll through
# the full --top range, just N rows at a time. The 4 reserved rows
# above the table: host/up/load (1) + mem (2) + cpu/disk/net (3) +
# table-header (4). _tui_rows is set by _tui_update_winsize.
fn tui_render_table_frame() {
    var sort_key = _tui_sort_key;
    var top_n    = _tui_top_n;
    # Slice E.5: reserve bottom row for the status line, so visible
    # process rows = _tui_rows - 5. The render still always paints
    # rows 1-4 (host/mem/cpu/table-header) and row _tui_rows (status).
    # M2.5: process-table view is now 1 row shorter to make room for
    # the gpu line at row 3. _tui_rows - 6 visible process rows; the
    # gpu line is only painted when mihi_gpu_count() > 0 — but the
    # row slot is reserved either way so re-renders are layout-stable
    # (gpu plugged at boot/removed at runtime would otherwise shift
    # the whole table on a refresh tick — too jarring).
    var max_rows = _tui_rows - 6;
    if (max_rows < 0) { max_rows = 0; }
    var buf[8192];

    # M2.5: identity reads (hostname / uptime / meminfo) route through
    # mihi. Per-frame deltas (cpu%, disk, net) stay chakshu-local.
    var uts[400];
    mihi_uname(&uts);

    # ----- row 1: host / uptime / load -----
    tty_cursor_home();
    _tui_color_bold(); syscall(1, 1, "host: ", 6); _tui_color_reset();
    var hn = mihi_hostname(&uts);
    syscall(1, 1, hn, strlen(hn));
    _tui_color_bold(); syscall(1, 1, "  up: ", 6); _tui_color_reset();
    snapshot_print_uptime(mihi_uptime_secs(&buf, 8192));
    _tui_color_bold(); syscall(1, 1, "  load: ", 8); _tui_color_reset();
    var la_n = proc_read("/proc/loadavg", &buf, 8192);
    if (la_n > 0) {
        var prefix = proc_loadavg_prefix_len(&buf, la_n);
        syscall(1, 1, &buf, prefix);
    }
    tty_clear_to_eol();

    # ----- row 2: memory -----
    tty_move(2, 1);
    var mem_total_b = mihi_mem_total(&buf, 8192);
    var mem_avail_b = mihi_mem_free(&buf, 8192);
    var mem_total_kb  = mem_total_b / 1024;
    var mem_used_mib  = (mem_total_b - mem_avail_b) / 1048576;
    var mem_total_mib = mem_total_b / 1048576;
    _tui_color_bold(); syscall(1, 1, "mem:  ", 6); _tui_color_reset();
    print_num(mem_used_mib);
    syscall(1, 1, " MiB used / ", 12);
    print_num(mem_total_mib);
    syscall(1, 1, " MiB total", 10);
    tty_clear_to_eol();

    # ----- row 3: GPU / accelerators (reserved slot) -----
    # When count == 0 the row is intentionally blank (still
    # tty_clear_to_eol so a previous frame's content goes away).
    tty_move(3, 1);
    var gpu_n = mihi_gpu_count();
    if (gpu_n > 0) {
        _tui_color_bold(); syscall(1, 1, "gpu:  ", 6); _tui_color_reset();
        var gi = 0;
        while (gi < gpu_n) {
            if (gi > 0) { syscall(1, 1, ", ", 2); }
            var gname = mihi_gpu_name(gi);
            if (gname != 0) {
                syscall(1, 1, gname, strlen(gname));
            }
            var gmem_b = mihi_gpu_memory_bytes(gi);
            if (gmem_b > 0) {
                syscall(1, 1, " (", 2);
                print_num(gmem_b / 1048576);
                syscall(1, 1, " MiB)", 5);
            }
            gi = gi + 1;
        }
    }
    tty_clear_to_eol();

    # ----- row 3: cpu / disk / net (delta-based, 100ms window) -----
    var sb1[8192];
    var db1[8192];
    var nb1[8192];
    var s1n = proc_read("/proc/stat",      &sb1, 8192);
    var d1n = proc_read("/proc/diskstats", &db1, 8192);
    var n1n = proc_read("/proc/net/dev",   &nb1, 8192);
    var cpu_active1 = 0; var cpu_total1 = 0;
    var sec_r1 = 0; var sec_w1 = 0;
    var rx1 = 0; var tx1 = 0;
    if (s1n > 0) { proc_stat_cpu_agg(&sb1, &cpu_active1, &cpu_total1); }
    if (d1n > 0) { proc_diskstats_agg(&db1, d1n, &sec_r1, &sec_w1); }
    if (n1n > 0) { proc_netdev_agg(&nb1, n1n, &rx1, &tx1); }
    var ncores = 1;
    if (s1n > 0) { ncores = proc_stat_ncores(&sb1, s1n); }
    processes_sample1();

    sleep_ms(SNAP_SAMPLE_MS);

    var s2n = proc_read("/proc/stat",      &sb1, 8192);
    var d2n = proc_read("/proc/diskstats", &db1, 8192);
    var n2n = proc_read("/proc/net/dev",   &nb1, 8192);
    var cpu_active2 = 0; var cpu_total2 = 0;
    var sec_r2 = 0; var sec_w2 = 0;
    var rx2 = 0; var tx2 = 0;
    if (s2n > 0) { proc_stat_cpu_agg(&sb1, &cpu_active2, &cpu_total2); }
    if (d2n > 0) { proc_diskstats_agg(&db1, d2n, &sec_r2, &sec_w2); }
    if (n2n > 0) { proc_netdev_agg(&nb1, n2n, &rx2, &tx2); }

    var cpu_pct = 0;
    var total_delta = cpu_total2 - cpu_total1;
    if (total_delta > 0) {
        cpu_pct = (cpu_active2 - cpu_active1) * 100 / total_delta;
    }
    var disk_rd_bps = (sec_r2 - sec_r1) * 512 * 1000 / SNAP_SAMPLE_MS;
    var disk_wr_bps = (sec_w2 - sec_w1) * 512 * 1000 / SNAP_SAMPLE_MS;
    var net_rx_bps  = (rx2 - rx1) * 1000 / SNAP_SAMPLE_MS;
    var net_tx_bps  = (tx2 - tx1) * 1000 / SNAP_SAMPLE_MS;

    # ----- row 4: cpu / disk / net (delta line) -----
    tty_move(4, 1);
    _tui_color_bold(); syscall(1, 1, "cpu:  ", 6); _tui_color_reset();
    _tui_color_pct_band(cpu_pct, 25, 70);
    print_num(cpu_pct);
    _tui_color_reset();
    _tui_color_bold(); syscall(1, 1, "%   disk: rd ", 13); _tui_color_reset();
    _snap_print_rate_bps(disk_rd_bps);
    _tui_color_bold(); syscall(1, 1, " wr ", 4); _tui_color_reset();
    _snap_print_rate_bps(disk_wr_bps);
    _tui_color_bold(); syscall(1, 1, "   net: rx ", 11); _tui_color_reset();
    _snap_print_rate_bps(net_rx_bps);
    _tui_color_bold(); syscall(1, 1, " tx ", 4); _tui_color_reset();
    _snap_print_rate_bps(net_tx_bps);
    tty_clear_to_eol();

    # ----- row 5+: process table (header + top-N rows) -----
    processes_sample2(total_delta, ncores, sort_key);
    tty_move(5, 1);
    syscall(1, 1, "   PID S  CPU%  MEM% CMD", 24);
    tty_clear_to_eol();

    # Slice E.5: build the filtered index list. Walks _proc_recs in
    # sorted order; appends matching abs indices to _tui_filtered_idx.
    # Empty filter → trivial pass-through (filtered_n == _proc_n).
    _tui_filtered_n = 0;
    var fi = 0;
    while (fi < _proc_n) {
        if (_tui_proc_matches_filter(fi) == 1) {
            store64(&_tui_filtered_idx + _tui_filtered_n * 8, fi);
            _tui_filtered_n = _tui_filtered_n + 1;
        }
        fi = fi + 1;
    }

    # max_navigable = total selectable rows (bound by --top + filtered
    # proc count, NOT by terminal height). max_rows = how many fit
    # on screen at once.
    var max_navigable = _tui_filtered_n;
    if (max_navigable > top_n) { max_navigable = top_n; }

    # Re-clamp selection + view_offset in case state shifted between
    # frames (terminal resized smaller, processes exited, sort
    # changed). Defensive — keeps the render valid even if the
    # input handlers somehow left things in a stale state.
    if (_tui_selected_idx >= max_navigable) {
        if (max_navigable > 0) { _tui_selected_idx = max_navigable - 1; } else { _tui_selected_idx = 0; }
    }
    if (_tui_view_offset > _tui_selected_idx) {
        _tui_view_offset = _tui_selected_idx;
    }
    var max_rows_for_clamp = max_rows;
    if (max_rows_for_clamp < 1) { max_rows_for_clamp = 1; }
    if (_tui_selected_idx >= _tui_view_offset + max_rows_for_clamp) {
        _tui_view_offset = _tui_selected_idx - max_rows_for_clamp + 1;
    }
    # Don't scroll past the end (e.g., view was offset for a list of
    # 50 procs but now only 5 exist).
    if (_tui_view_offset + max_rows > max_navigable) {
        _tui_view_offset = max_navigable - max_rows;
        if (_tui_view_offset < 0) { _tui_view_offset = 0; }
    }

    # Number of rows we'll actually draw — limited by both the screen
    # cap and what's available starting from view_offset.
    var n = max_rows;
    if (n > max_navigable - _tui_view_offset) {
        n = max_navigable - _tui_view_offset;
    }
    if (n < 0) { n = 0; }

    var i = 0;
    while (i < n) {
        tty_move(6 + i, 1);
        # filtered_pos = position within the filtered/sorted list;
        # abs_idx = position within _proc_recs (resolved via filtered_idx).
        # Selection lives in filtered space — match against filtered_pos.
        var filtered_pos = _tui_view_offset + i;
        var abs_idx = load64(&_tui_filtered_idx + filtered_pos * 8);
        # Reverse-video the selected row. The invert sequence stays
        # active through the row content AND the trailing tty_clear_to_eol
        # so the highlight extends edge-to-edge — matches htop's
        # selection bar. Reset before moving to the next row.
        # Suppress per-cell colors inside the highlight so the bar
        # stays visually clean (red CPU% on a reverse-video row is
        # noisy and hard to read).
        var is_sel = 0;
        if (filtered_pos == _tui_selected_idx) {
            _tui_invert_on();
            _tui_color_suppress = 1;
            is_sel = 1;
        }

        var rec = _proc_recs + abs_idx * PROC_REC_SIZE;
        var pid = load64(rec + 0);
        var cpu = load64(rec + 8);
        var rss = load64(rec + 16);
        var st  = load64(rec + 24);
        var mem = 0;
        if (mem_total_kb > 0) { mem = rss * 400 / mem_total_kb; }
        _tui_color_dim(); _proc_print_int_pad(pid, 6); _tui_color_reset();
        syscall(1, 1, " ", 1);
        var sc[2];
        store8(&sc, st);
        store8(&sc + 1, 0);
        _tui_color_state(st); syscall(1, 1, &sc, 1); _tui_color_reset();
        _tui_color_pct_band(cpu, 25, 70); _proc_print_int_pad(cpu, 6); _tui_color_reset();
        _tui_color_pct_band(mem, 50, 80); _proc_print_int_pad(mem, 6); _tui_color_reset();
        syscall(1, 1, " ", 1);
        # cmdline read (top-N only — same as plain mode). Clip to
        # terminal width: the per-row prefix (pid 6 + space + state
        # 1 + cpu 6 + mem 6 + space) is exactly 21 columns, so
        # avail = _tui_cols - 21 is what we have for cmdline. If the
        # text exceeds that and the terminal auto-wraps, the cursor
        # advances past row `_tui_rows` and the alt-screen scrolls
        # the top header off — which is the bug report this fixes.
        var pid_str[24];
        _proc_int_to_cstr(pid, &pid_str);
        var cmd_buf[256];
        var cmd_n = _proc_read_cmdline(&pid_str, &cmd_buf, PROC_CMDLINE_MAX);
        var avail = _tui_cols - 21;
        if (avail < 0) { avail = 0; }
        if (cmd_n > 0) {
            var to_print = cmd_n;
            if (to_print > avail) { to_print = avail; }
            if (to_print > 0) { syscall(1, 1, &cmd_buf, to_print); }
        } else {
            # Bracketed [comm] for kernel threads. Keep brackets if
            # they fit; otherwise just print the comm truncated.
            var comm_p = rec + 32;
            var comm_l = strlen(comm_p);
            if (comm_l > 16) { comm_l = 16; }
            var bracketed_total = comm_l + 2;
            if (bracketed_total <= avail) {
                syscall(1, 1, "[", 1);
                syscall(1, 1, comm_p, comm_l);
                syscall(1, 1, "]", 1);
            }
            else {
                var to_print = comm_l;
                if (to_print > avail) { to_print = avail; }
                if (to_print > 0) { syscall(1, 1, comm_p, to_print); }
            }
        }
        tty_clear_to_eol();
        if (is_sel == 1) {
            _tui_color_suppress = 0;
            _tui_invert_off();
        }
        i = i + 1;
    }

    # Wipe any leftover rows between the last process row and the
    # status row. tty_move(row, col) past the terminal's bottom row
    # scrolls the alt-screen on some terminals — guard the move with
    # `< _tui_rows` (not `<=`) since the status row at `_tui_rows`
    # is rewritten unconditionally below.
    if (6 + n < _tui_rows) {
        tty_move(6 + n, 1);
        tty_clear_to_eos();
    }

    # ----- row _tui_rows: status line -----
    _tui_render_status();

    return 0;
}

# Append `s` (cstring) into `buf` at position `pos`, capped at `max`.
# Returns bytes appended. Used by _tui_render_status to compose the
# status line into a stack buffer with truncation, so a narrow
# terminal can't wrap the status into the table area.
fn _tui_status_append(buf, pos, max, s) {
    var slen = strlen(s);
    var avail = max - pos;
    if (slen > avail) { slen = avail; }
    if (slen <= 0) { return 0; }
    var i = 0;
    while (i < slen) {
        store8(buf + pos + i, load8(s + i));
        i = i + 1;
    }
    return slen;
}

# Append raw bytes from `src` (length `src_n`) into `buf` at `pos`,
# capped at `max`. Used to copy the filter buffer into the status
# line — those bytes are NOT cstring-terminated.
fn _tui_status_append_bytes(buf, pos, max, src, src_n) {
    var avail = max - pos;
    if (src_n > avail) { src_n = avail; }
    if (src_n <= 0) { return 0; }
    var i = 0;
    while (i < src_n) {
        store8(buf + pos + i, load8(src + i));
        i = i + 1;
    }
    return src_n;
}

# Render the status line at row _tui_rows. Composes into a 256-byte
# stack buffer with terminal-width clipping, then writes the whole
# row in one syscall (avoids partial-paint flicker).
fn _tui_render_status() {
    tty_move(_tui_rows, 1);
    var sbuf[256];
    var pos = 0;
    var max = _tui_cols;
    if (max > 256) { max = 256; }

    if (_tui_mode == TUI_MODE_FILTER) {
        pos = pos + _tui_status_append(&sbuf, pos, max, "filter: ");
        pos = pos + _tui_status_append_bytes(&sbuf, pos, max, &_tui_filter_buf, _tui_filter_n);
        pos = pos + _tui_status_append(&sbuf, pos, max, "_  (Enter: apply, Esc: clear)");
    }
    elif (_tui_mode == TUI_MODE_CONFIRM_KILL) {
        # "Kill PID <N>? [y/N]" — explicit-uppercase N signals that
        # No is the default (any non-y key cancels).
        pos = pos + _tui_status_append(&sbuf, pos, max, "Kill PID ");
        var pid_str[24];
        var pid_len = _proc_int_to_cstr(_tui_kill_pid, &pid_str);
        pos = pos + _tui_status_append_bytes(&sbuf, pos, max, &pid_str, pid_len);
        pos = pos + _tui_status_append(&sbuf, pos, max, "? [y/N]");
    }
    else {
        # ↑↓ are 3-byte UTF-8 each (E2 86 91 / E2 86 93). The literal
        # below uses the byte escapes directly so the source isn't
        # sensitive to editor encoding.
        pos = pos + _tui_status_append(&sbuf, pos, max, "[\xe2\x86\x91\xe2\x86\x93] move  [s] sort  [f] filter  [k] kill  [?] explain  [q] quit");
        if (_tui_filter_n > 0) {
            pos = pos + _tui_status_append(&sbuf, pos, max, "  filter: ");
            pos = pos + _tui_status_append_bytes(&sbuf, pos, max, &_tui_filter_buf, _tui_filter_n);
        }
    }

    if (pos > 0) { syscall(1, 1, &sbuf, pos); }
    tty_clear_to_eol();
    return 0;
}

# Dispatch one key event according to current mode. Returns 1 if
# the caller should exit the main loop (q / Ctrl-C / EOF in Normal
# mode; EOF in any mode), 0 otherwise. Each non-exit dispatch
# triggers an immediate re-render so the user sees feedback before
# the next refresh tick.
#
# Extracted from tui_run's epoll/stdin branch into a separate fn
# so the buffer-drain loop at the top of tui_run can share the
# same dispatch path — without this, batched keys (e.g., rapid
# typing in Filter mode) get dropped because epoll never refires.
fn _tui_dispatch_key(k) {
    if (_tui_mode == TUI_MODE_FILTER) {
        # Filter mode: typed printables append to buffer, Backspace
        # deletes, Enter exits to Normal (filter persists), Esc
        # clears + exits to Normal.
        if (k < 0)       { return 1; }
        elif (k == 0x1b) { _tui_filter_clear(); _tui_mode = TUI_MODE_NORMAL; tui_render_frame(); }
        elif (k == 13)   { _tui_mode = TUI_MODE_NORMAL; tui_render_frame(); }
        elif (k == 0x7f) { _tui_filter_backspace(); tui_render_frame(); }
        elif (k == 8)    { _tui_filter_backspace(); tui_render_frame(); }
        else {
            if (k >= 32) {
                if (k <= 126) {
                    _tui_filter_append_byte(k);
                    tui_render_frame();
                }
            }
        }
        return 0;
    }
    if (_tui_mode == TUI_MODE_CONFIRM_KILL) {
        # 'y'/'Y' confirms; anything else cancels back to Normal.
        # q intentionally cancels-only here so an accidental q during
        # confirm doesn't quit the whole app.
        if (k == 121)  { sys_kill(_tui_kill_pid, TUI_KILL_SIGNUM); _tui_mode = TUI_MODE_NORMAL; tui_render_frame(); }
        elif (k == 89) { sys_kill(_tui_kill_pid, TUI_KILL_SIGNUM); _tui_mode = TUI_MODE_NORMAL; tui_render_frame(); }
        elif (k < 0)   { return 1; }
        else { _tui_mode = TUI_MODE_NORMAL; tui_render_frame(); }
        return 0;
    }
    # Normal mode. In focus mode (--pid set) most table keybinds are
    # no-ops (no selection, no sort, no filter); only q/Ctrl-C/k apply.
    if (k == 113)        { return 1; }                                                      # 'q'
    elif (k == 3)        { return 1; }                                                      # Ctrl-C
    elif (k < 0)         { return 1; }                                                      # EOF / read error
    elif (k == 107)      {                                                                  # 'k'
        if (_tui_focus_pid != 0) {
            # Focus mode — kill target is the focused pid.
            _tui_kill_pid = _tui_focus_pid;
            _tui_mode = TUI_MODE_CONFIRM_KILL;
            tui_render_frame();
        } else {
            # Table mode — kill target is the selected row.
            if (_tui_filtered_n > 0) {
                var sel_filt = _tui_selected_idx;
                if (sel_filt >= _tui_filtered_n) { sel_filt = _tui_filtered_n - 1; }
                var abs_idx = load64(&_tui_filtered_idx + sel_filt * 8);
                _tui_kill_pid = load64(_proc_recs + abs_idx * PROC_REC_SIZE + 0);
                _tui_mode = TUI_MODE_CONFIRM_KILL;
                tui_render_frame();
            }
        }
    }
    elif (_tui_focus_pid != 0) {
        # Focus mode swallows the rest — no selection / sort / filter.
        return 0;
    }
    elif (k == KEY_UP)   { _tui_select_up();   tui_render_frame(); }
    elif (k == KEY_DOWN) { _tui_select_down(); tui_render_frame(); }
    elif (k == 115)      { _tui_cycle_sort();  tui_render_frame(); }                        # 's'
    elif (k == 102)      { _tui_mode = TUI_MODE_FILTER; tui_render_frame(); }               # 'f'
    elif (k == 63)       {                                                                  # '?'
        # AI explain — overlay the selected pid's hoosh answer (shu-ai
        # build via src/ai.cyr) or a "not in this build" notice (lean shu
        # via src/ai_stub.cyr). ai_tui_explain takes over the screen and
        # blocks for a key; we repaint the frame when it returns.
        if (_tui_filtered_n > 0) {
            var sel_e = _tui_selected_idx;
            if (sel_e >= _tui_filtered_n) { sel_e = _tui_filtered_n - 1; }
            var abs_e = load64(&_tui_filtered_idx + sel_e * 8);
            var epid = load64(_proc_recs + abs_e * PROC_REC_SIZE + 0);
            ai_tui_explain(epid);
            tui_render_frame();
        }
    }
    return 0;
}

# Run the TUI. Returns EXIT_OK on clean quit, EXIT_ERR on setup
# failure (most likely: stdin is not a TTY — e.g. `shu < /dev/null`
# or invoked from a CI runner).
#
# refresh_ms = milliseconds between frame renders (1000 = 1 Hz).
# sort_key   = SORT_CPU/MEM/PID/NAME passed to processes_sample2.
# top_n      = process-table row count.
# color_mode = 0 never, 1 auto, 2 always (Slice G.2). auto and
#              always currently both enable color in TUI; $TERM
#              detection for true auto behavior is M3 polish.
# focus_pid  = 0 → table mode (default); else → render the focus
#              view for that pid. Caller (main.cyr) validates the
#              pid exists before invoking. (Slice G.3)
fn tui_run(refresh_ms, sort_key, top_n, color_mode, focus_pid) {
    # tty_raw fails if the ioctl can't get termios — typically
    # because the fd isn't a TTY. Surface a clear error and steer
    # the user toward the always-pipeable `-p` mode.
    if (tty_raw(0) < 0) {
        eprintln("chakshu: stdin is not a TTY (use -p for plain mode)");
        return EXIT_ERR;
    }

    # Seed interactive state from CLI params. The render loop reads
    # these globals each frame; keypresses (s, ↑, ↓, f) mutate them in
    # place so changes apply immediately.
    _tui_sort_key     = sort_key;
    _tui_top_n        = top_n;
    _tui_selected_idx = 0;
    _tui_view_offset  = 0;
    _tui_mode         = TUI_MODE_NORMAL;
    _tui_filter_n     = 0;

    # Color: --color {auto, always} → enabled; never → disabled.
    # auto and always behave identically in TUI mode for now.
    _tui_color_enabled = 1;
    if (color_mode == 0) { _tui_color_enabled = 0; }
    _tui_color_suppress = 0;

    # --pid focus pid (0 = table mode). Validation happens in main.cyr;
    # by the time we get here, focus_pid (if non-zero) refers to a
    # pid that existed at startup. The render handles the
    # later-disappeared case gracefully.
    _tui_focus_pid = focus_pid;

    # Open two signalfds — one for exit signals (HUP/INT/TERM) so
    # external `kill <pid>` cleanly tears down, one for SIGWINCH so
    # the render loop wakes on terminal resize. Two separate fds
    # rather than one combined mask gives clearer dispatch (fd
    # identity == intent; no need to inspect ssi_signo). Then add
    # all three (stdin, exit_sig, winch_sig) to one epoll set.
    #
    # Each step degrades gracefully on failure: if signalfd setup
    # fails, drop to direct stdin (Slice A behavior). Better to
    # launch with reduced signal handling than refuse to launch.
    var sfd_exit  = tty_open_signalfd(TTY_SIGMASK_EXIT);
    var sfd_winch = tty_open_signalfd(TTY_SIGMASK_WINCH);
    var epfd = 0 - 1;
    if (sfd_exit >= 0) {
        epfd = sys_epoll_create();
        if (epfd >= 0) {
            # data field distinguishes which fd fired:
            #   data == 0 → stdin keystroke
            #   data == 1 → exit signalfd (HUP/INT/TERM)
            #   data == 2 → winch signalfd (terminal resize)
            var ev_in   = epoll_event_new(EPOLLIN, 0);
            var ev_exit = epoll_event_new(EPOLLIN, 1);
            sys_epoll_ctl(epfd, EPOLL_CTL_ADD, 0,        ev_in);
            sys_epoll_ctl(epfd, EPOLL_CTL_ADD, sfd_exit, ev_exit);
            if (sfd_winch >= 0) {
                var ev_winch = epoll_event_new(EPOLLIN, 2);
                sys_epoll_ctl(epfd, EPOLL_CTL_ADD, sfd_winch, ev_winch);
            }
        }
    }

    # Read initial terminal size into the cache before first render
    # so the layout's max-rows cap is correct from frame 1.
    _tui_update_winsize();

    tty_alt_enter();
    tty_cursor_hide();
    tty_clear();

    # Initial render so the user sees content before the first
    # epoll_wait timeout fires.
    tui_render_frame();

    # Input + refresh loop. epoll_wait(timeout=refresh_ms) returns:
    #   n == 0        → timeout, re-render
    #   n > 0, data=1 → exit signalfd, drain + exit
    #   n > 0, data=2 → winch signalfd, drain + refresh winsize + render
    #   n > 0, data=0 → stdin, read key, dispatch q/Ctrl-C/EOF
    # If epoll setup failed, fall back to a blocking stdin read with
    # no refresh and no signal handling — degraded but functional.
    #
    # Before each epoll_wait, drain any buffered input bytes
    # left over from a previous read (rapid typing or batched arrivals
    # during a render tick can leave 1-3 bytes pending). Without this
    # drain, epoll_wait would block waiting for new bytes to arrive
    # while we still have unprocessed events on hand.
    var loop = 1;
    while (loop == 1) {
        while (_tui_input_pending() == 1) {
            var k_drain = _tui_read_key();
            if (_tui_dispatch_key(k_drain) == 1) { loop = 0; }
            if (loop == 0) { break; }
        }
        if (loop == 0) { break; }
        if (epfd >= 0) {
            var events[16];
            var n = sys_epoll_wait(epfd, &events, 1, refresh_ms);
            if (n == 0) {
                tui_render_frame();
                continue;
            }
            if (n < 0) { continue; }
            var which = load64(&events + 4);
            if (which == 1) {
                # Exit signalfd — drain (struct signalfd_siginfo = 128
                # bytes) then exit cleanly.
                var siginfo_exit[128];
                file_read(sfd_exit, &siginfo_exit, 128);
                loop = 0;
            }
            elif (which == 2) {
                # Winch signalfd — drain, refresh winsize, full-clear
                # (terminal geometry changed; old positions may be
                # stale), then re-render. tty_clear avoids ghost text
                # in the now-shifted alt-screen buffer.
                var siginfo_winch[128];
                file_read(sfd_winch, &siginfo_winch, 128);
                _tui_update_winsize();
                tty_clear();
                tui_render_frame();
            }
            else {
                # stdin — dispatch by mode
                var k = _tui_read_key();
                if (_tui_dispatch_key(k) == 1) { loop = 0; }
            }
        } else {
            # Degraded path — no signal multiplexing AND no refresh
            # (blocking stdin only). Keystroke needed to exit.
            var k = _tui_read_key();
            if (_tui_dispatch_key(k) == 1) { loop = 0; }
        }
    }

    _tui_teardown();
    if (sfd_exit  >= 0) { file_close(sfd_exit); }
    if (sfd_winch >= 0) { file_close(sfd_winch); }
    if (epfd      >= 0) { file_close(epfd); }
    return EXIT_OK;
}
