# ai.cyr — AI integration: prompt assembly + secret redaction + the
# `--explain` one-shot. M3 foundation (chakshu v0.7.2).
#
# Scope at 0.7.2 (per docs/development/roadmap.md, M3 — AI integration):
#   - ai_redact_cmdline  — niyama re2-driven secret-value redaction (§6.2)
#   - ai_build_prompt    — assemble the explain prompt from process +
#                          system facts the user can already see (§6.2)
#   - ai_explain         — `--explain <pid>` one-shot: gather, redact,
#                          assemble, print the (redacted) context that
#                          WOULD be sent, and report daimon transport
#                          status. The live JSON-RPC call + streamed
#                          response render land at 0.7.3; --watch /
#                          --with-logs at 0.7.6.
#
# Privacy (design-spec §6.2 + CLAUDE.md): the prompt carries only data
# the user can already see in the TUI / -p surface — process identity,
# state, mem, and a REDACTED cmdline. No env vars, no /home contents,
# no untrimmed args. Secret values (--password=, --token=, *KEY*=, ...)
# are stripped before assembly.

# Cap on cmdline bytes assembled into the prompt — design-spec §6.2:
# "the first 256 bytes of /proc/[pid]/cmdline".
var AI_CMDLINE_CAP = 256;

# --- small output appenders -------------------------------------------
# Each returns the new output cursor; all clamp at cap-1 to leave room
# for a trailing null.

fn _ai_app(out, pos, cap, s) {
    var sl = strlen(s);
    var i = 0;
    while (i < sl) {
        if (pos < cap - 1) { store8(out + pos, load8(s + i)); pos = pos + 1; }
        i = i + 1;
    }
    return pos;
}

fn _ai_app_ch(out, pos, cap, ch) {
    if (pos < cap - 1) { store8(out + pos, ch); pos = pos + 1; }
    return pos;
}

fn _ai_app_n(out, pos, cap, num) {
    var nb[24];
    var nl = _proc_int_to_cstr(num, &nb);
    var i = 0;
    while (i < nl) {
        if (pos < cap - 1) { store8(out + pos, load8(&nb + i)); pos = pos + 1; }
        i = i + 1;
    }
    return pos;
}

# --- secret redaction (niyama re2) ------------------------------------

# Lazily-compiled re2 NFA flagging a secret-looking key. Matches anywhere
# in the key token (the part before '='): password / token / secret / key
# / passwd, case-insensitive on the leading letter and on KEY. Compiled
# once on first use. _tried guards against recompiling after a failure.
var _ai_secret_nfa       = 0;
var _ai_secret_nfa_tried = 0;

fn _ai_secret_pattern_nfa() {
    if (_ai_secret_nfa_tried == 0) {
        _ai_secret_nfa_tried = 1;
        _ai_secret_nfa = niyama_re2_compile("[Pp]assword|[Tt]oken|[Ss]ecret|[Kk][Ee][Yy]|[Pp]asswd");
    }
    return _ai_secret_nfa;
}

# Is the key token buf[key_off, key_end) secret-looking? Copies the key
# into a scratch cstring and runs the re2 search. Fail-safe: if the
# detector NFA is unavailable (compile failed), treat the key as secret
# so a broken regex never leaks a value.
fn _ai_key_is_secret(buf, key_off, key_end) {
    var nfa = _ai_secret_pattern_nfa();
    if (nfa == 0) { return 1; }
    var klen = key_end - key_off;
    if (klen <= 0) { return 0; }
    if (klen > 63) { klen = 63; }
    var kbuf[64];
    var i = 0;
    while (i < klen) {
        store8(&kbuf + i, load8(buf + key_off + i));
        i = i + 1;
    }
    store8(&kbuf + klen, 0);
    if (niyama_re2_search(nfa, &kbuf) >= 0) { return 1; }
    return 0;
}

# Redact secret VALUES from a printable (space-separated) command line.
# For each space-delimited token containing '=', if the key (before '=')
# is secret-looking, the value (after '=') is replaced with "***";
# otherwise the token is copied verbatim. Tokens without '=' are copied
# verbatim. Output is null-terminated. Returns output length (excl null).
#
# in_buf must be null-terminated; in_len is its length (excl null).
fn ai_redact_cmdline(in_buf, in_len, out, cap) {
    var op = 0;
    var i = 0;
    while (i < in_len) {
        var tok_start = i;
        # token spans [tok_start, j) until next space or end
        var j = i;
        while (j < in_len) {
            if (load8(in_buf + j) == 32) { break; }
            j = j + 1;
        }
        # locate '=' within the token
        var eq = 0 - 1;
        var t = tok_start;
        while (t < j) {
            if (load8(in_buf + t) == 61) { eq = t; break; }
            t = t + 1;
        }
        var redact = 0;
        if (eq >= 0) {
            if (_ai_key_is_secret(in_buf, tok_start, eq) == 1) { redact = 1; }
        }
        if (redact == 1) {
            # copy key + '=' verbatim, then "***"
            var k = tok_start;
            while (k <= eq) {
                if (op < cap - 1) { store8(out + op, load8(in_buf + k)); op = op + 1; }
                k = k + 1;
            }
            var s = 0;
            while (s < 3) {
                if (op < cap - 1) { store8(out + op, 42); op = op + 1; }  # '*'
                s = s + 1;
            }
        } else {
            var c = tok_start;
            while (c < j) {
                if (op < cap - 1) { store8(out + op, load8(in_buf + c)); op = op + 1; }
                c = c + 1;
            }
        }
        # re-emit the single token separator (space), then advance
        if (j < in_len) {
            if (op < cap - 1) { store8(out + op, 32); op = op + 1; }
            i = j + 1;
        } else {
            i = j;
        }
    }
    store8(out + op, 0);
    return op;
}

# --- prompt assembly (§6.2) -------------------------------------------

# Assemble the explain prompt into `out` (cap bytes) from facts the user
# can already see. `comm`, `redacted`, and `sysinfo` are cstrings;
# `state_ch` is the ASCII process-state byte. Returns prompt length
# (excl null). Pure formatter — no I/O, unit-tested.
fn ai_build_prompt(out, cap, pid, comm, state_ch, ppid, uid, rss_kb, redacted, sysinfo) {
    var pos = 0;
    pos = _ai_app(out, pos, cap, "Explain this Linux process using only the facts below.\n\n");
    pos = _ai_app(out, pos, cap, "process: ");
    pos = _ai_app(out, pos, cap, comm);
    pos = _ai_app(out, pos, cap, " (pid ");
    pos = _ai_app_n(out, pos, cap, pid);
    pos = _ai_app(out, pos, cap, ", ppid ");
    pos = _ai_app_n(out, pos, cap, ppid);
    pos = _ai_app(out, pos, cap, ", uid ");
    pos = _ai_app_n(out, pos, cap, uid);
    pos = _ai_app(out, pos, cap, ")\n");
    pos = _ai_app(out, pos, cap, "state:   ");
    pos = _ai_app_ch(out, pos, cap, state_ch);
    pos = _ai_app(out, pos, cap, "\n");
    pos = _ai_app(out, pos, cap, "rss:     ");
    pos = _ai_app_n(out, pos, cap, rss_kb);
    pos = _ai_app(out, pos, cap, " kB\n");
    pos = _ai_app(out, pos, cap, "command: ");
    pos = _ai_app(out, pos, cap, redacted);
    pos = _ai_app(out, pos, cap, "\n");
    pos = _ai_app(out, pos, cap, "system:  ");
    pos = _ai_app(out, pos, cap, sysinfo);
    pos = _ai_app(out, pos, cap, "\n");
    store8(out + pos, 0);
    return pos;
}

# One-line system summary: "load <l1 l5 l15>  mem <used>/<total> MiB".
# Uses the same identity/load sources as the -p header.
fn _ai_system_summary(out, cap) {
    var pos = 0;
    pos = _ai_app(out, pos, cap, "load ");
    var lbuf[8192];
    var ln = proc_read("/proc/loadavg", &lbuf, 8192);
    if (ln > 0) {
        var lp = proc_loadavg_prefix_len(&lbuf, ln);
        var i = 0;
        while (i < lp) {
            if (pos < cap - 1) { store8(out + pos, load8(&lbuf + i)); pos = pos + 1; }
            i = i + 1;
        }
    }
    pos = _ai_app(out, pos, cap, "  mem ");
    var scratch[8192];
    var mt = mihi_mem_total(&scratch, 8192);
    var mf = mihi_mem_free(&scratch, 8192);
    var used_mib  = (mt - mf) / 1048576;
    var total_mib = mt / 1048576;
    pos = _ai_app_n(out, pos, cap, used_mib);
    pos = _ai_app(out, pos, cap, "/");
    pos = _ai_app_n(out, pos, cap, total_mib);
    pos = _ai_app(out, pos, cap, " MiB");
    store8(out + pos, 0);
    return pos;
}

# --- hoosh transport (HTTP — M3 live, v0.7.3) -------------------------
# design-spec §6.3's "daimon over Unix socket" framing is stale: the AGNOS
# LLM gateway `hoosh` is an OpenAI-compatible HTTP server (hoosh ADR-001) —
# POST /v1/chat/completions, default :8088. chakshu reaches it through
# sandhi's HTTP client (folded into stdlib). $CHAKSHU_HOOSH_URL and
# $CHAKSHU_MODEL override the endpoint + model. (Env reads here are for
# transport addressing, NOT prompt content — privacy rule intact.)

var AI_DEFAULT_HOOSH_URL = "http://127.0.0.1:8088/v1/chat/completions";
var AI_DEFAULT_MODEL     = "default";

# Copy $name into `out`, or `fallback` when unset. Returns length.
fn _ai_env_or(out, cap, name, fallback) {
    var v = getenv(name);
    var pos = 0;
    if (v != 0) { pos = _ai_app(out, pos, cap, v); }
    else        { pos = _ai_app(out, pos, cap, fallback); }
    store8(out + pos, 0);
    return pos;
}

# Escape in_len bytes of `in_buf` as a JSON string value (no surrounding
# quotes) into `out`: ", \, \n, \r, \t handled; other C0 controls dropped.
# Returns output length. Pure — unit-tested.
fn _ai_json_escape(in_buf, in_len, out, cap) {
    var op = 0;
    var i = 0;
    while (i < in_len) {
        var c = load8(in_buf + i);
        if (c == 34)   { if (op < cap - 2) { store8(out + op, 92); op = op + 1; store8(out + op, 34);  op = op + 1; } }
        elif (c == 92) { if (op < cap - 2) { store8(out + op, 92); op = op + 1; store8(out + op, 92);  op = op + 1; } }
        elif (c == 10) { if (op < cap - 2) { store8(out + op, 92); op = op + 1; store8(out + op, 110); op = op + 1; } }
        elif (c == 13) { if (op < cap - 2) { store8(out + op, 92); op = op + 1; store8(out + op, 114); op = op + 1; } }
        elif (c == 9)  { if (op < cap - 2) { store8(out + op, 92); op = op + 1; store8(out + op, 116); op = op + 1; } }
        elif (c >= 32) { if (op < cap - 1) { store8(out + op, c); op = op + 1; } }
        i = i + 1;
    }
    store8(out + op, 0);
    return op;
}

# Extract the first `"content":"..."` string value from an OpenAI-style
# response `body` into `out`, unescaping \n \t \r \" \\ \/. Returns output
# length, or -1 if no content field is present (e.g. an error body).
# Best-effort; full JSON parsing is sandhi's job if a richer path is needed.
# Pure — unit-tested.
fn _ai_extract_content(body, body_len, out, cap) {
    var needle = "\"content\":\"";
    var nlen = strlen(needle);
    var start = 0 - 1;
    var i = 0;
    while (i + nlen <= body_len) {
        if (memeq(body + i, needle, nlen) == 1) { start = i + nlen; break; }
        i = i + 1;
    }
    if (start < 0) { return 0 - 1; }
    var op = 0;
    var j = start;
    while (j < body_len) {
        var c = load8(body + j);
        if (c == 34) { break; }                 # closing unescaped quote
        if (c == 92) {                            # escape sequence
            j = j + 1;
            if (j >= body_len) { break; }
            var e = load8(body + j);
            if (e == 110)   { c = 10; }           # \n
            elif (e == 116) { c = 9; }            # \t
            elif (e == 114) { c = 13; }           # \r
            elif (e == 34)  { c = 34; }           # \"
            elif (e == 92)  { c = 92; }           # \\
            elif (e == 47)  { c = 47; }           # \/
            else            { c = e; }            # passthrough
        }
        if (op < cap - 1) { store8(out + op, c); op = op + 1; }
        j = j + 1;
    }
    store8(out + op, 0);
    return op;
}

# Build the request headers for a hoosh call: Content-Type, plus
# Authorization: Bearer <$CHAKSHU_HOOSH_TOKEN> when that env is set.
# hoosh 2.3.5+ enforces bearer-token auth on /v1/* when tokens are
# configured (a token-less gateway "allows all", so the header is
# omitted when the env is unset). Reusable by the POST and the SSE
# stream path. Returns a sandhi headers handle.
fn _ai_hoosh_headers() {
    var h = sandhi_headers_new();
    sandhi_headers_set_a(default_alloc(), h, "Content-Type", "application/json");
    var token = getenv("CHAKSHU_HOOSH_TOKEN");
    if (token != 0) {
        var auth[1024];
        var ap = 0;
        ap = _ai_app(&auth, ap, 1024, "Bearer ");
        ap = _ai_app(&auth, ap, 1024, token);
        store8(&auth + ap, 0);
        sandhi_headers_set_a(default_alloc(), h, "Authorization", &auth);
    }
    return h;
}

# POST the prompt to hoosh as an OpenAI chat request; write the answer
# into `out`. Returns:
#   >=0 answer length | -1 transport error | -2 non-200 | -3 no content.
# Happy-path needs a live hoosh to verify; the failure paths degrade
# gracefully (caller falls back to the redacted-context preview).
fn ai_hoosh_explain(prompt, plen, out, cap) {
    var url[512];
    _ai_env_or(&url, 512, "CHAKSHU_HOOSH_URL", AI_DEFAULT_HOOSH_URL);
    var model[128];
    _ai_env_or(&model, 128, "CHAKSHU_MODEL", AI_DEFAULT_MODEL);

    var esc_prompt[4096];
    _ai_json_escape(prompt, plen, &esc_prompt, 4096);
    var esc_model[256];
    _ai_json_escape(&model, strlen(&model), &esc_model, 256);

    # {"model":"<m>","messages":[{"role":"user","content":"<prompt>"}]}
    var body[6144];
    var bp = 0;
    bp = _ai_app(&body, bp, 6144, "{\"model\":\"");
    bp = _ai_app(&body, bp, 6144, &esc_model);
    bp = _ai_app(&body, bp, 6144, "\",\"messages\":[{\"role\":\"user\",\"content\":\"");
    bp = _ai_app(&body, bp, 6144, &esc_prompt);
    bp = _ai_app(&body, bp, 6144, "\"}]}");
    store8(&body + bp, 0);

    var h = _ai_hoosh_headers();
    var resp = sandhi_http_post(&url, h, &body, bp);
    if (resp == 0) { return 0 - 1; }
    var st = sandhi_http_status(resp);
    if (st == 0)   { return 0 - 1; }   # no HTTP status → transport failure
    if (st != 200) { return 0 - 2; }
    return _ai_extract_content(sandhi_http_body(resp), sandhi_http_body_len(resp), out, cap);
}

# --- `--explain <pid>` one-shot ---------------------------------------

# Gather the process facts, redact the cmdline, assemble the prompt, and
# print it as the context that --explain WILL send to daimon. Returns
# EXIT_OK, or EXIT_ERR if the pid is gone / unparseable. The live call +
# streamed answer land in v0.7.3; this cut makes the (redacted) context
# auditable — which is exactly the privacy posture design-spec §2.2 / §6
# asks for ("AI is opt-in and visible").
# Build the redacted explain prompt for `pid` into `out`. Returns the
# prompt length, or -1 (no such process) / -2 (unparseable stat). Shared
# by ai_explain (one-shot) and ai_tui_explain (overlay). Does no printing.
fn _ai_prompt_for_pid(pid, out, cap) {
    var pid_str[24];
    _proc_int_to_cstr(pid, &pid_str);

    # /proc/<pid>/stat → state, ticks, rss (pages), comm
    var stat_path[64];
    proc_pid_path(&pid_str, "/stat", &stat_path);
    var stat_buf[8192];
    var sn = file_read_all(&stat_path, &stat_buf, 8191);
    if (sn <= 0) { return 0 - 1; }
    var rec[48];
    if (proc_pid_stat_parse(&stat_buf, sn, &rec) != 0) { return 0 - 2; }
    var state_ch  = load64(&rec + 0);
    var rss_pages = load64(&rec + 16);
    var comm      = &rec + 24;
    var rss_kb    = rss_pages * 4;          # 4 KiB pages

    # /proc/<pid>/status → PPid, Uid
    var status_path[64];
    proc_pid_path(&pid_str, "/status", &status_path);
    var status_buf[8192];
    var stn = file_read_all(&status_path, &status_buf, 8191);
    var ppid_val = 0;
    var uid_val  = 0;
    if (stn > 0) {
        store8(&status_buf + stn, 0);
        ppid_val = proc_meminfo_field(&status_buf, "PPid:");
        uid_val  = proc_meminfo_field(&status_buf, "Uid:");
    }

    # /proc/<pid>/cmdline → printable → redacted (capped per §6.2)
    var cmd_raw[512];
    var craw_n = _proc_read_cmdline(&pid_str, &cmd_raw, 512);
    if (craw_n > AI_CMDLINE_CAP) {
        craw_n = AI_CMDLINE_CAP;
        store8(&cmd_raw + craw_n, 0);
    }
    var cmd_red[512];
    if (craw_n > 0) {
        ai_redact_cmdline(&cmd_raw, craw_n, &cmd_red, 512);
    } else {
        # kernel thread / unreadable cmdline — bracket the comm
        store8(&cmd_red, 91);               # '['
        var cl = strlen(comm);
        var ci = 0;
        while (ci < cl) {
            store8(&cmd_red + 1 + ci, load8(comm + ci));
            ci = ci + 1;
        }
        store8(&cmd_red + 1 + cl, 93);      # ']'
        store8(&cmd_red + 1 + cl + 1, 0);
    }

    var sysinfo[256];
    _ai_system_summary(&sysinfo, 256);

    return ai_build_prompt(out, cap, pid, comm, state_ch, ppid_val, uid_val, rss_kb, &cmd_red, &sysinfo);
}

fn ai_explain(pid) {
    var prompt[2048];
    var plen = _ai_prompt_for_pid(pid, &prompt, 2048);
    if (plen == 0 - 1) {
        var ps[24];
        _proc_int_to_cstr(pid, &ps);
        eprint_cstr("chakshu: --explain ");
        eprint_cstr(&ps);
        eprintln(": no such process");
        return EXIT_ERR;
    }
    if (plen == 0 - 2) {
        eprintln("chakshu: --explain: cannot parse process stat");
        return EXIT_ERR;
    }

    # Send to hoosh; print its answer. On ANY failure, fall back to the
    # redacted-context preview so --explain always yields something useful
    # and auditable, even with no gateway running.
    var answer[16384];
    var rc = ai_hoosh_explain(&prompt, plen, &answer, 16384);
    if (rc >= 0) {
        syscall(1, 1, &answer, rc);
        syscall(1, 1, "\n", 1);
        return EXIT_OK;
    }

    var url[512];
    _ai_env_or(&url, 512, "CHAKSHU_HOOSH_URL", AI_DEFAULT_HOOSH_URL);
    eprint_cstr("chakshu: hoosh ");
    if (rc == 0 - 1)   { eprint_cstr("unreachable at "); }
    elif (rc == 0 - 2) { eprint_cstr("returned a non-200 status — "); }
    else               { eprint_cstr("response had no content field — "); }
    eprint_cstr(&url);
    eprintln("; showing the redacted context that would be sent:");
    eprintln("");
    syscall(1, 1, &prompt, plen);
    return EXIT_OK;
}

# --- in-TUI explain overlay (the `?` key in shu-ai) -------------------

# Write a null-terminated string to stdout via strlen — avoids the
# multi-byte UTF-8 byte-count trap (— and … are 3 bytes each).
fn _ai_puts(s) {
    syscall(1, 1, s, strlen(s));
    return 0;
}

# Print `n` bytes of `buf` for the overlay, translating bare \n → \r\n so
# each line starts at column 0 in raw mode. Long lines wrap in the term.
fn _ai_overlay_print(buf, n) {
    var i = 0;
    var start = 0;
    while (i < n) {
        if (load8(buf + i) == 10) {
            if (i > start) { syscall(1, 1, buf + start, i - start); }
            syscall(1, 1, "\r\n", 2);
            start = i + 1;
        }
        i = i + 1;
    }
    if (n > start) { syscall(1, 1, buf + start, n - start); }
    return 0;
}

# Block for one keypress from stdin (raw mode is already set by the TUI).
fn _ai_overlay_wait_key() {
    var kb[4];
    syscall(0, 0, &kb, 1);      # read(fd=0, buf, 1)
    return 0;
}

# Non-blocking check for a cancel keypress (Esc or q) on stdin. poll(2)
# with a 0 ms timeout so it never blocks the stream. Returns 1 to cancel.
fn _ai_stream_check_cancel() {
    var pfd[8];
    store64(&pfd, 4294967296);          # pollfd { fd=0, events=POLLIN(1)<<32, revents=0 }
    var r = syscall(7, &pfd, 1, 0);     # poll(fds, nfds=1, timeout=0)
    if (r > 0) {
        var kb[4];
        var nr = syscall(0, 0, &kb, 1);
        if (nr > 0) {
            var c = load8(&kb);
            if (c == 27)  { return 1; }  # Esc
            if (c == 113) { return 1; }  # q
        }
    }
    return 0;
}

# Per-event SSE callback. sandhi parses the stream and calls this with each
# parsed event; `ctx` is an i64* the cb bumps per rendered delta so the
# caller can fall back when nothing arrived. OpenAI deltas carry
# `"delta":{"content":"…"}` — _ai_extract_content's `"content":"` needle
# matches; the `[DONE]` sentinel has no content and is skipped. Returns
# 1 to continue, 0 to stop (Esc/q).
fn _ai_stream_cb(ctx, ev) {
    var data = sandhi_sse_event_data(ev);
    if (data != 0) {
        var chunk[2048];
        var n = _ai_extract_content(data, strlen(data), &chunk, 2048);
        if (n > 0) {
            _ai_overlay_print(&chunk, n);
            store64(ctx, load64(ctx) + 1);
        }
    }
    if (_ai_stream_check_cancel() == 1) { return 0; }
    return 1;
}

# Stream the hoosh answer, rendering deltas as they arrive via _ai_stream_cb.
# `rendered_ctx` is an i64* the cb bumps per delta. Adds "stream":true to the
# OpenAI request. Returns sandhi_http_stream's result (informational).
fn ai_hoosh_stream(prompt, plen, rendered_ctx) {
    var url[512];
    _ai_env_or(&url, 512, "CHAKSHU_HOOSH_URL", AI_DEFAULT_HOOSH_URL);
    var model[128];
    _ai_env_or(&model, 128, "CHAKSHU_MODEL", AI_DEFAULT_MODEL);

    var esc_prompt[4096];
    _ai_json_escape(prompt, plen, &esc_prompt, 4096);
    var esc_model[256];
    _ai_json_escape(&model, strlen(&model), &esc_model, 256);

    var body[6144];
    var bp = 0;
    bp = _ai_app(&body, bp, 6144, "{\"model\":\"");
    bp = _ai_app(&body, bp, 6144, &esc_model);
    bp = _ai_app(&body, bp, 6144, "\",\"stream\":true,\"messages\":[{\"role\":\"user\",\"content\":\"");
    bp = _ai_app(&body, bp, 6144, &esc_prompt);
    bp = _ai_app(&body, bp, 6144, "\"}]}");
    store8(&body + bp, 0);

    var h = _ai_hoosh_headers();
    return sandhi_http_stream(&url, "POST", h, &body, bp, &_ai_stream_cb, rendered_ctx);
}

# `?` handler for the shu-ai TUI: take over the screen and STREAM hoosh's
# answer for the selected pid, rendering deltas as they arrive (Esc/q
# cancels). If nothing streams (gateway down / empty), fall back to the
# redacted-context preview. Waits for a key; the caller repaints the frame
# on return. Mirrors ai_explain's privacy + fallback semantics.
fn ai_tui_explain(pid) {
    var prompt[2048];
    var plen = _ai_prompt_for_pid(pid, &prompt, 2048);

    var pid_str[24];
    _proc_int_to_cstr(pid, &pid_str);

    tty_clear();
    tty_move(1, 1);
    _ai_puts("AI explain — PID ");
    _ai_puts(&pid_str);
    _ai_puts("  (Esc/q cancels)\r\n\r\n");

    if (plen < 0) {
        _ai_puts("  process is gone.\r\n  [any key to close]");
        _ai_overlay_wait_key();
        return 0;
    }

    var rendered[8];
    store64(&rendered, 0);
    ai_hoosh_stream(&prompt, plen, &rendered);

    if (load64(&rendered) == 0) {
        # nothing streamed (gateway unreachable / empty) — show the context
        _ai_puts("  hoosh unavailable — redacted context that would be sent:\r\n\r\n");
        _ai_overlay_print(&prompt, plen);
    }
    _ai_puts("\r\n\r\n  [any key to close]");
    _ai_overlay_wait_key();
    return 0;
}
