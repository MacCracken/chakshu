# proc.cyr — /proc parsers (M1 Slice A surface)
#
# Per design-spec §3, all data comes from the Linux /proc and /sys
# interfaces — no libc, no procps, no FFI. This module owns the read
# + parse layer; src/snapshot.cyr owns the rendering / orchestration.
#
# All parsers operate on a caller-provided buffer (see snapshot.cyr).
# Single shared buffer is fine because the snapshot path is sequential:
# read → parse → print → reuse for next file. No concurrent borrows.
#
# Slice A (this file) covers the four single-read sources:
#   /proc/sys/kernel/hostname  — string
#   /proc/uptime               — "<secs>.<frac> <idle>.<frac>"
#   /proc/loadavg              — "L1 L5 L15 R/T LASTPID"
#   /proc/meminfo              — "Key:  <kB> kB" lines
#
# Slice B will add /proc/stat, /proc/diskstats, /proc/net/dev (delta-based).
# Slice C will add the /proc/[pid]/{stat,status,cmdline} walker.
# When Slice B/C land we may promote to src/proc/{cpu,disk,net,pid}.cyr —
# the CLAUDE.md architecture stub already pre-supposes a proc/ subdir.

# Read a /proc file fully into `buf` (must be at least maxlen bytes), then
# null-terminate. Returns bytes read, or the negative file_open errno on
# error. The null terminator goes at buf[n] so callers can hand the buffer
# to strstr / atoi without re-doing length math.
fn proc_read(path, buf, maxlen) {
    var n = file_read_all(path, buf, maxlen - 1);
    if (n < 0) { return n; }
    store8(buf + n, 0);
    return n;
}

# Find a "Key:" line in a /proc/meminfo-style buffer and return its
# integer value (in kB for meminfo). The scan keys on "<key>" + skip
# whitespace + atoi. Returns 0 if the key is not present — meminfo
# values are never legitimately zero for any field chakshu reads
# (MemTotal, MemAvailable, SwapTotal, etc.), so 0 is an unambiguous
# "not found" sentinel without needing an out-param error channel.
fn proc_meminfo_field(buf, key) {
    var off = strstr(buf, key);
    if (off < 0) { return 0; }
    var i = off + strlen(key);
    # Skip spaces and tabs after the colon.
    while (1 == 1) {
        var c = load8(buf + i);
        if (c != 32) { if (c != 9) { break; } }
        i = i + 1;
    }
    return atoi(buf + i);
}

# Parse the integer second-count from /proc/uptime, which is shaped
# "<secs>.<frac> <idle>.<frac>\n". atoi stops at the first '.', giving
# us whole-second uptime — the fractional part is below the resolution
# of the "Nd HH:MM" display anyway.
fn proc_uptime_secs(buf) {
    return atoi(buf);
}

# Return the byte offset of the 3rd space in a /proc/loadavg buffer of
# length n. The first three space-separated fields are L1/L5/L15; the
# rest is "R/T LASTPID\n" which we don't show in plain mode. Returns n
# (the full length) if fewer than 3 spaces are present, so callers can
# safely print buf..buf+result without bounds-checking again.
fn proc_loadavg_prefix_len(buf, n) {
    var i: i64 = 0;
    var spaces: i64 = 0;
    while (i < n) {
        if (load8(buf + i) == 32) {
            spaces = spaces + 1;
            if (spaces == 3) { return i; }
        }
        i = i + 1;
    }
    return n;
}

# Trim a single trailing '\n' from a length-n buffer in place by
# replacing it with a null terminator and returning the new length.
# /proc files almost universally end in \n; the hostname read in
# particular benefits from this so println() doesn't double-newline.
fn proc_trim_trailing_nl(buf, n) {
    if (n <= 0) { return n; }
    if (load8(buf + n - 1) != 10) { return n; }
    store8(buf + n - 1, 0);
    return n - 1;
}

# ===================================================================
# Slice B — delta-based parsers (/proc/stat, /proc/diskstats,
# /proc/net/dev). Each helper takes a `cursor` pointer (address of an
# i64 local in the caller) so successive helpers can chew through the
# same buffer without redundant scans.
# ===================================================================

# Skip horizontal whitespace at *cursor (space, tab); leave newline /
# null / digit alone. Updates *cursor in place.
fn _proc_skip_ws(buf, cursor) {
    var i = load64(cursor);
    while (1 == 1) {
        var c = load8(buf + i);
        if (c != 32) { if (c != 9) { break; } }
        i = i + 1;
    }
    store64(cursor, i);
    return 0;
}

# Skip everything up to and including the next '\n', or until '\0'.
# Used to advance past a record we've finished parsing.
fn _proc_skip_line(buf, cursor) {
    var i = load64(cursor);
    while (1 == 1) {
        var c = load8(buf + i);
        if (c == 0) { break; }
        if (c == 10) { i = i + 1; break; }
        i = i + 1;
    }
    store64(cursor, i);
    return 0;
}

# Skip whitespace then read a decimal integer at *cursor. Handles a
# single leading '-' so the parser can advance past signed fields like
# /proc/[pid]/stat's `tpgid` (-1 when there's no controlling tty) and
# `nice` (negative for boosted-priority processes). Returns the parsed
# value (0 if no digits). Advances *cursor to one past the last digit.
# Stops on null, newline, or any other non-digit.
#
# Name kept as _uint for back-compat with the slice B callers that only
# ever see unsigned counters; the sign handling is purely a parse-skip
# robustness fix and doesn't change their behavior.
fn _proc_next_uint(buf, cursor) {
    _proc_skip_ws(buf, cursor);
    var i = load64(cursor);
    var neg = 0;
    if (load8(buf + i) == 45) {     # '-'
        neg = 1;
        i = i + 1;
    }
    var v = 0;
    while (1 == 1) {
        var c = load8(buf + i);
        if (c < 48) { break; }
        if (c > 57) { break; }
        v = v * 10 + (c - 48);
        i = i + 1;
    }
    store64(cursor, i);
    if (neg == 1) { return 0 - v; }
    return v;
}

# Skip whitespace, return the offset of the next non-whitespace byte
# (the start of the next "word" — name, label, etc.). *cursor is left
# at that offset; caller should follow with _proc_skip_word to consume.
fn _proc_word_start(buf, cursor) {
    _proc_skip_ws(buf, cursor);
    return load64(cursor);
}

# Skip a "word" — non-whitespace bytes — at *cursor. Stops at any
# whitespace, null, newline, or ':' (so it works for both diskstats
# device names and netdev "iface:" labels — the colon stays under
# the cursor for the caller to handle).
fn _proc_skip_word(buf, cursor) {
    var i = load64(cursor);
    while (1 == 1) {
        var c = load8(buf + i);
        if (c == 0)  { break; }
        if (c == 10) { break; }
        if (c == 32) { break; }
        if (c == 9)  { break; }
        if (c == 58) { break; }   # ':' — netdev label terminator
        i = i + 1;
    }
    store64(cursor, i);
    return 0;
}

# Parse the aggregate "cpu " line from /proc/stat (the first line). The
# 10 fields per `man 5 proc` are user, nice, system, idle, iowait, irq,
# softirq, steal, guest, guest_nice. Idle = idle + iowait; Active =
# Total - Idle. Caller saves Active+Total at sample 1, again at sample
# 2, and computes pct = 100 * (active2-active1) / (total2-total1).
#
# Returns 0 on success, non-zero if the buffer doesn't begin with "cpu ".
fn proc_stat_cpu_agg(buf, out_active, out_total) {
    if (load8(buf + 0) != 99) { return 1; }   # 'c'
    if (load8(buf + 1) != 112) { return 1; }  # 'p'
    if (load8(buf + 2) != 117) { return 1; }  # 'u'
    var cursor = 3;
    var total = 0;
    var idle = 0;
    var f = 0;
    while (f < 10) {
        var v = _proc_next_uint(buf, &cursor);
        total = total + v;
        if (f == 3) { idle = idle + v; }
        if (f == 4) { idle = idle + v; }
        f = f + 1;
    }
    store64(out_active, total - idle);
    store64(out_total, total);
    return 0;
}

# Should this diskstats device line be excluded from the aggregate?
# Excludes synthetic / virtual block devices that would otherwise
# inflate the I/O total: loop, ram, zram, dm-, mdN. Partitions still
# double-count their parent disk in slice B's sum (qualitative I/O
# view); a precise filter using sysfs lives at M2.
fn _proc_diskstats_excluded(buf, name_off) {
    if (memeq(buf + name_off, "loop", 4) == 1) { return 1; }
    if (memeq(buf + name_off, "ram",  3) == 1) { return 1; }
    if (memeq(buf + name_off, "zram", 4) == 1) { return 1; }
    if (memeq(buf + name_off, "dm-",  3) == 1) { return 1; }
    if (memeq(buf + name_off, "md",   2) == 1) {
        var c = load8(buf + name_off + 2);
        if (c >= 48) { if (c <= 57) { return 1; } }
    }
    return 0;
}

# Sum sectors_read and sectors_written across all "real" block devices
# in a /proc/diskstats buffer of length n. Sector size is 512 bytes
# (Linux convention regardless of physical sector size). Caller diffs
# two samples and multiplies by 512 for bytes.
#
# Per kernel Documentation/admin-guide/iostats.rst, the per-line layout
# after the leading <major> <minor> <name> header is:
#   [0] reads completed   [1] reads merged       [2] sectors read
#   [3] read time (ms)    [4] writes completed   [5] writes merged
#   [6] sectors written   [7] write time (ms)    [8] I/Os in flight
#   [9] time in queue     [10] weighted time     [11+] discard / flush
fn proc_diskstats_agg(buf, n, out_sec_read, out_sec_writ) {
    var sec_read_total = 0;
    var sec_writ_total = 0;
    var cursor = 0;
    while (cursor < n) {
        # major, minor — discard
        _proc_next_uint(buf, &cursor);
        _proc_next_uint(buf, &cursor);
        # device name
        var name_off = _proc_word_start(buf, &cursor);
        if (cursor >= n) { return 0; }
        _proc_skip_word(buf, &cursor);
        # 7 numeric fields up to and including sectors_written
        _proc_next_uint(buf, &cursor);                       # reads
        _proc_next_uint(buf, &cursor);                       # read_merges
        var sec_r = _proc_next_uint(buf, &cursor);           # sectors_read
        _proc_next_uint(buf, &cursor);                       # read_time
        _proc_next_uint(buf, &cursor);                       # writes
        _proc_next_uint(buf, &cursor);                       # write_merges
        var sec_w = _proc_next_uint(buf, &cursor);           # sectors_written
        # Skip the rest of the line
        _proc_skip_line(buf, &cursor);
        if (_proc_diskstats_excluded(buf, name_off) == 0) {
            sec_read_total = sec_read_total + sec_r;
            sec_writ_total = sec_writ_total + sec_w;
        }
    }
    store64(out_sec_read, sec_read_total);
    store64(out_sec_writ, sec_writ_total);
    return 0;
}

# Count the number of online CPU cores by counting "cpuN" lines in a
# /proc/stat buffer (the aggregate "cpu " line at the top is skipped).
# Used to scale per-process CPU% from share-of-system to htop-style
# share-of-one-core (a thread pegging one core reads ~100%, regardless
# of how many other cores are idle).
fn proc_stat_ncores(buf, n) {
    var cores = 0;
    var i = 0;
    # Skip the aggregate "cpu " line.
    _proc_skip_line(buf, &i);
    while (i < n) {
        # Match "cpu" + digit at line start.
        if (load8(buf + i) == 99) {            # 'c'
            if (load8(buf + i + 1) == 112) {   # 'p'
                if (load8(buf + i + 2) == 117) { # 'u'
                    var c = load8(buf + i + 3);
                    if (c >= 48) { if (c <= 57) { cores = cores + 1; } }
                }
            }
        }
        _proc_skip_line(buf, &i);
    }
    if (cores == 0) { cores = 1; }   # always at least one core
    return cores;
}

# True if `name` (null-terminated cstring) is a /proc PID directory —
# i.e. all-digit, non-empty. /proc contains both numeric PID dirs and
# symbolic ones ("self", "thread-self", "kcore", "cpuinfo", etc.) and
# we want only the former.
fn proc_is_pid_name(name) {
    var i = 0;
    while (1 == 1) {
        var c = load8(name + i);
        if (c == 0) { break; }
        if (c < 48) { return 0; }
        if (c > 57) { return 0; }
        i = i + 1;
    }
    if (i == 0) { return 0; }
    return 1;
}

# Build "/proc/<pid>/<suffix>" into out_buf as a null-terminated
# cstring. Returns the byte length (excl. null). pid_str and suffix
# are both null-terminated cstrings.
fn proc_pid_path(pid_str, suffix, out_buf) {
    var off = 0;
    var prefix = "/proc/";
    var pi = 0;
    while (pi < 6) {
        store8(out_buf + off, load8(prefix + pi));
        off = off + 1; pi = pi + 1;
    }
    var p = 0;
    while (1 == 1) {
        var c = load8(pid_str + p);
        if (c == 0) { break; }
        store8(out_buf + off, c);
        off = off + 1; p = p + 1;
    }
    var s = 0;
    while (1 == 1) {
        var c = load8(suffix + s);
        if (c == 0) { break; }
        store8(out_buf + off, c);
        off = off + 1; s = s + 1;
    }
    store8(out_buf + off, 0);
    return off;
}

# Parse /proc/[pid]/stat into a 48-byte output record laid out as:
#   off  0  state  (i64; low byte holds the ASCII state char R/S/D/Z/T)
#   off  8  ticks  (i64; utime + stime — caller deltas across samples)
#   off 16  rss    (i64; pages — multiply by page size for bytes)
#   off 24  comm   (16 bytes; null-terminated, TASK_COMM_LEN-capped name)
#
# The stat line shape per `man 5 proc` is:
#   pid (comm) state ppid pgrp ... [13 ints] utime stime [8 ints] rss [...]
# `comm` is in parens and may itself contain spaces and parens (kernel
# truncates to 15 chars but doesn't escape internal punctuation).
# Parse strategy: pid is before the first '('; comm spans first '(' to
# the LAST ')' in the buffer; the rest is plain space-separated ints.
#
# Returns 0 on success; non-zero on malformed input.
fn proc_pid_stat_parse(buf, n, out_rec) {
    # Locate first '(' and last ')' — robust against comm containing
    # nested parens (rare but possible).
    var first_paren = 0 - 1;
    var last_paren  = 0 - 1;
    var i = 0;
    while (i < n) {
        var c = load8(buf + i);
        if (c == 40) { if (first_paren < 0) { first_paren = i; } }
        if (c == 41) { last_paren = i; }
        i = i + 1;
    }
    if (first_paren < 0) { return 1; }
    if (last_paren  < 0) { return 1; }
    if (last_paren <= first_paren) { return 1; }

    var comm_off = first_paren + 1;
    var comm_len = last_paren - comm_off;

    var cursor = last_paren + 1;
    if (load8(buf + cursor) == 32) { cursor = cursor + 1; }
    # State char.
    var state = load8(buf + cursor);
    cursor = cursor + 1;

    # Skip 10 ints: ppid pgrp session tty_nr tpgid flags minflt cminflt majflt cmajflt
    var skip = 0;
    while (skip < 10) {
        _proc_next_uint(buf, &cursor);
        skip = skip + 1;
    }
    var utime = _proc_next_uint(buf, &cursor);
    var stime = _proc_next_uint(buf, &cursor);
    # Skip 8 ints: cutime cstime priority nice num_threads itrealvalue starttime vsize
    skip = 0;
    while (skip < 8) {
        _proc_next_uint(buf, &cursor);
        skip = skip + 1;
    }
    var rss = _proc_next_uint(buf, &cursor);

    store64(out_rec + 0,  state);
    store64(out_rec + 8,  utime + stime);
    store64(out_rec + 16, rss);

    # Copy comm into out_rec+24, cap at 15 bytes + null.
    var copy_len = comm_len;
    if (copy_len > 15) { copy_len = 15; }
    var k = 0;
    while (k < copy_len) {
        store8(out_rec + 24 + k, load8(buf + comm_off + k));
        k = k + 1;
    }
    while (k < 16) {
        store8(out_rec + 24 + k, 0);
        k = k + 1;
    }
    return 0;
}

# Sum rx_bytes and tx_bytes across non-loopback interfaces in a
# /proc/net/dev buffer of length n. The first two lines are headers
# ("Inter-|..." and " face |..."); they're skipped by line count, not
# by content match, since the heading text varies by kernel version.
#
# Per-interface line shape (after leading whitespace):
#   <iface>: <16 numeric fields>
# Fields: rx_bytes rx_pkts rx_errs rx_drop rx_fifo rx_frame rx_compressed
#         rx_multicast tx_bytes tx_pkts tx_errs tx_drop tx_fifo tx_colls
#         tx_carrier tx_compressed
fn proc_netdev_agg(buf, n, out_rx, out_tx) {
    var rx_total = 0;
    var tx_total = 0;
    var cursor = 0;

    # Skip the two header lines.
    _proc_skip_line(buf, &cursor);
    _proc_skip_line(buf, &cursor);

    while (cursor < n) {
        _proc_skip_ws(buf, &cursor);
        if (cursor >= n) { break; }
        if (load8(buf + cursor) == 0) { break; }
        var name_off = cursor;
        _proc_skip_word(buf, &cursor);
        var name_len = cursor - name_off;
        # Expect ':' here
        if (load8(buf + cursor) != 58) {
            _proc_skip_line(buf, &cursor);
            continue;
        }
        cursor = cursor + 1;   # past ':'
        # 16 numeric fields; we keep [0]=rx_bytes and [8]=tx_bytes.
        var rx_bytes = 0;
        var tx_bytes = 0;
        var f = 0;
        while (f < 16) {
            var v = _proc_next_uint(buf, &cursor);
            if (f == 0) { rx_bytes = v; }
            if (f == 8) { tx_bytes = v; }
            f = f + 1;
        }
        _proc_skip_line(buf, &cursor);
        # Exclude loopback (name == "lo"). Loopback traffic isn't
        # network traffic in the sense the user cares about for `-p`.
        var is_lo = 0;
        if (name_len == 2) {
            if (load8(buf + name_off) == 108) {       # 'l'
                if (load8(buf + name_off + 1) == 111) { # 'o'
                    is_lo = 1;
                }
            }
        }
        if (is_lo == 0) {
            rx_total = rx_total + rx_bytes;
            tx_total = tx_total + tx_bytes;
        }
    }
    store64(out_rx, rx_total);
    store64(out_tx, tx_total);
    return 0;
}
